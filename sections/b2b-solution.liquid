<style>
.agri-container {
  padding: 60px 20px;
  max-width: 600px;
  margin: auto;
  font-family: Arial, sans-serif;
  text-align: left;
  background: #ffffff;
}

/* Main Heading */
.agri-heading {
  font-size: 36px;
  font-weight: bold;
  margin-bottom: 40px;
  color: #16a34a;
  text-align: left; 
}

/* Each block */
.agri-block {
  margin-bottom: 40px;
}

/* Section Title */
.agri-title {
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 15px;
  text-align: left;
}

/* List */
.agri-list {
  padding-left: 20px;
  text-align: left; 
}

/* List items */
.agri-list li {
  margin-bottom: 10px;
  line-height: 1.6;
}

/* Divider */
.agri-block:not(:last-child) {
  border-bottom: 1px solid #eee;
  padding-bottom: 25px;
}

@media(max-width:768px){
  .agri-container {
  padding: 40px 20px;
  }
.agri-heading {
  font-size: 26px;
  margin-bottom: 20px;
}
.agri-title {
  font-size: 20px;
}
.agri-block {
  margin-bottom: 20px;
}
.agri-block:not(:last-child) {
    padding-bottom: 15px;
}
}
</style>

<div class="agri-container">

  <!-- Main Heading -->
  <div class="agri-heading">
    {{ section.settings.main_heading }}
  </div>

  <!-- Dynamic Blocks -->
  {% for block in section.blocks %}
    <div class="agri-block">

      <!-- Auto Number + Title -->
      <div class="agri-title">
        {{ forloop.index }}. {{ block.settings.title }}
      </div>

      <!-- Points -->
      <ul class="agri-list">
        {% assign points = block.settings.points | newline_to_br | split: '<br />' %}
        {% for point in points %}
          {% if point != blank %}
            <li>{{ point }}</li>
          {% endif %}
        {% endfor %}
      </ul>

    </div>
  {% endfor %}

</div>

{% schema %}
{
  "name": "B2B Agriculture",
  "settings": [
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "B2B Agriculture Solutions"
    }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Content Section",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Section Title",
          "default": "Section Title"
        },
        {
          "type": "textarea",
          "id": "points",
          "label": "Points (one per line)",
          "default": "Point 1\nPoint 2\nPoint 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "B2B Agriculture"
    }
  ]
}
{% endschema %}