

<style>
.agri-section {
  padding: 50px 20px;
  background: #f5f7f2;
  text-align: center;
}
.agri-heading {
  font-size: 32px;
  font-weight: bold;
}
.agri-subheading {
  margin-bottom: 30px;
  color: #555;
}
.agri-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}
.agri-card {
  background: #fff;
  padding: 20px;
  border-radius: 10px;
  transition: 0.3s;
}
.agri-card:hover {
  transform: translateY(-5px);
}
.agri-card img {
  max-width: 80px;
  margin-bottom: 15px;
}
.agri-title {
  font-size: 18px;
  font-weight: 600;
}
.agri-desc {
  font-size: 14px;
  color: #666;
}
</style>

<div class="agri-section">
  <div class="agri-heading">{{ section.settings.heading }}</div>
  <div class="agri-subheading">{{ section.settings.subheading }}</div>

  <div class="agri-grid">
    {% for block in section.blocks %}
      <div class="agri-card">
        {% if block.settings.icon %}
          <img src="{{ block.settings.icon | img_url: 'medium' }}" alt="">
        {% endif %}
        <div class="agri-title">{{ block.settings.title }}</div>
        <div class="agri-desc">{{ block.settings.description }}</div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "B2B Agriculture",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "B2B Agriculture Solutions"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "Empowering agri-business with smart solutions"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Service Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Service Title",
          "default": "Service Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Service description here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "B2B Agriculture",
      "category": "Custom"
    }
  ]
}
{% endschema %}