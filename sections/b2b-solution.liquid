<style>
.agri-container {
  padding: 60px 20px;
  max-width: 900px;
  margin: auto;
  font-family: Arial, sans-serif;
  text-align: center;
}

.agri-heading {
  font-size: 36px;
  font-weight: bold;
  margin-bottom: 40px;
  color: #16a34a;
}

.agri-block {
  margin-bottom: 35px;
}

.agri-title {
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 12px;
}

.agri-list {
  list-style-position: inside;
  padding: 0;
}

.agri-list li {
  margin-bottom: 8px;
  text-align: center;
}
</style>

<div class="agri-container">

  <!-- Main Heading -->
  <div class="agri-heading">
    {{ section.settings.main_heading }}
  </div>

  <!-- Dynamic Blocks -->
  {% for block in section.blocks %}
    <div class="agri-block">

      <!-- Auto Number + Title -->
      <div class="agri-title">
        {{ forloop.index }}. {{ block.settings.title }}
      </div>

      <!-- Points -->
      <ul class="agri-list">
        {% assign points = block.settings.points | newline_to_br | split: '<br />' %}
        {% for point in points %}
          {% if point != blank %}
            <li>{{ point }}</li>
          {% endif %}
        {% endfor %}
      </ul>

    </div>
  {% endfor %}

</div>

{% schema %}
{
  "name": "B2B Agriculture",
  "settings": [
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Our Solutions"
    }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Content Section",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Section Title",
          "default": "Section Title"
        },
        {
          "type": "textarea",
          "id": "points",
          "label": "Points (one per line)",
          "default": "Point 1\nPoint 2\nPoint 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "B2B Agriculture"
    }
  ]
}
{% endschema %}