<style>
.agri-container {
  padding: 50px 20px;
  max-width: 1000px;
  margin: auto;
  font-family: Arial, sans-serif;
}

.agri-heading {
     font-size: 36px;
    font-weight: bold;
    margin-bottom: 30px;
    text-align: center;
    color: #16a34a;
}

.agri-block {
  margin-bottom: 25px;
}

.agri-title {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 10px;
}

.agri-list {
  padding-left: 20px;
}

.agri-list li {
  margin-bottom: 6px;
}
</style>

<div class="agri-container">

  <!-- Main Heading -->
  <div class="agri-heading">
    {{ section.settings.main_heading }}
  </div>

  <!-- Dynamic Blocks -->
  {% for block in section.blocks %}
    <div class="agri-block">
      <div class="agri-title">
        {{ block.settings.title }}
      </div>

      <ul class="agri-list">
        {% assign points = block.settings.points | newline_to_br | split: '<br />' %}
        {% for point in points %}
          {% if point != blank %}
            <li>{{ point }}</li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  {% endfor %}

</div>

{% schema %}
{
  "name": "B2B Agriculture",
  "settings": [
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Our Solutions"
    }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Content Section",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Section Title",
          "default": "Section Title"
        },
        {
          "type": "textarea",
          "id": "points",
          "label": "Points (one per line)",
          "default": "Point 1\nPoint 2\nPoint 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "B2B Agriculture"
    }
  ]
}
{% endschema %}