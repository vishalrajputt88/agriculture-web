{% comment %} Bhumi Agro Industries - About Us Dynamic Section {% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

<style>
.bag-about *{box-sizing:border-box}
.bag-about{font-family:'DM Sans',sans-serif}

/* HERO */
.bag-hero{
  background:linear-gradient(135deg,#0d3d0d 0%,#1e6b1e 45%,#0d3d0d 100%);
  padding:80px 24px 90px;text-align:center;position:relative;overflow:hidden;
}
.bag-hero::before{content:'';position:absolute;top:-80px;left:-80px;width:280px;height:280px;border-radius:50%;background:rgba(255,255,255,0.04)}
.bag-hero::after{content:'';position:absolute;bottom:-100px;right:-60px;width:360px;height:360px;border-radius:50%;background:rgba(255,255,255,0.03)}
.bag-badge{
  display:inline-block;background:rgba(127,232,127,0.15);color:#7fe87f;
  font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;
  padding:7px 20px;border-radius:30px;border:1px solid rgba(127,232,127,0.3);margin-bottom:28px;
}
.bag-hero h1{
  font-family:'Playfair Display',serif;font-size:clamp(28px,5vw,54px);font-weight:900;
  color:#fff;line-height:1.18;margin-bottom:24px;position:relative;z-index:1;
}
.bag-hero h1 em{color:#7fe87f;font-style:normal}
.bag-hero-desc{
  font-size:16px;color:rgba(255,255,255,0.78);max-width:780px;margin:0 auto;
  line-height:1.85;position:relative;z-index:1;
}

/* STATS */
.bag-stats{display:grid;grid-template-columns:repeat(4,1fr);background:#fff;border-top:4px solid #1e6b1e}
.bag-stat{padding:28px 16px;text-align:center;border-right:1px solid #e8f5e8}
.bag-stat:last-child{border-right:none}
.bag-stat-num{font-family:'Playfair Display',serif;font-size:36px;font-weight:700;color:#1e6b1e;line-height:1;display:block}
.bag-stat-lbl{font-size:12px;color:#666;margin-top:6px;font-weight:500;letter-spacing:.4px;line-height:1.4}

/* INTRO */
.bag-intro-wrap{background:#f8fdf4;padding:64px 40px}
.bag-intro{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;max-width:1100px;margin:0 auto}
.bag-intro-img-inner{
  background:linear-gradient(145deg,#1e6b1e,#3a9a3a);
  border-radius:20px;padding:48px 36px;text-align:center;
  min-height:300px;display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.bag-intro-img-inner .big-icon{font-size:80px;margin-bottom:20px;display:block;animation:float 3s ease-in-out infinite}
.bag-intro-img-inner blockquote{color:rgba(255,255,255,0.85);font-size:15px;line-height:1.7;font-style:italic;margin:0}
.bag-label{font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:#1e6b1e;margin-bottom:12px;display:block}
.bag-intro h2{font-family:'Playfair Display',serif;font-size:clamp(22px,2.5vw,32px);color:#0d3d0d;line-height:1.3;margin-bottom:20px;font-weight:700}
.bag-intro-body p{font-size:15px;color:#3a5a3a;line-height:1.85;margin-bottom:14px}
.bag-divider{display:flex;align-items:center;gap:16px;margin:24px 0}
.bag-divider-line{flex:1;height:1px;background:#c8e8c8}

/* VISION MISSION */
.bag-vm{background:#0d3d0d;padding:64px 40px}
.bag-vm-inner{max-width:1100px;margin:0 auto}
.bag-vm-title{text-align:center;font-family:'Playfair Display',serif;font-size:clamp(22px,3vw,36px);color:#fff;margin-bottom:48px;font-weight:700}
.bag-vm-title span{color:#7fe87f}
.bag-vm-cards{display:grid;grid-template-columns:1fr 1fr;gap:28px}
.bag-vm-card{background:rgba(255,255,255,0.06);border:1px solid rgba(127,232,127,0.2);border-radius:20px;padding:40px 36px;position:relative;overflow:hidden;transition:background .3s}
.bag-vm-card:hover{background:rgba(255,255,255,0.1)}
.bag-vm-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#1e6b1e,#7fe87f)}
.bag-vm-card .vm-icon{font-size:40px;margin-bottom:18px;display:block}
.bag-vm-card h3{font-family:'Playfair Display',serif;font-size:22px;color:#7fe87f;margin-bottom:14px;font-weight:700}
.bag-vm-card p{font-size:15px;color:rgba(255,255,255,0.78);line-height:1.85}

/* PRODUCTS */
.bag-products{padding:64px 40px;background:#fff}
.bag-prod-inner{max-width:1100px;margin:0 auto}
.bag-sec-head{text-align:center;margin-bottom:48px}
.bag-sec-head h2{font-family:'Playfair Display',serif;font-size:clamp(24px,3vw,36px);color:#0d3d0d;margin-bottom:10px;font-weight:700}
.bag-sec-head p{font-size:15px;color:#5a7a5a;max-width:600px;margin:0 auto;line-height:1.7}
.bag-line{width:56px;height:4px;background:linear-gradient(90deg,#1e6b1e,#7fe87f);border-radius:2px;margin:14px auto 0}
.bag-prod-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px}
.bag-prod-card{border-radius:16px;padding:32px 24px;border:1.5px solid #e0f0e0;background:#f8fdf4;transition:all .3s;position:relative;overflow:hidden}
.bag-prod-card::after{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,#1e6b1e,#7fe87f)}
.bag-prod-card:hover{transform:translateY(-8px);box-shadow:0 24px 48px rgba(30,107,30,0.14);border-color:#1e6b1e}
.bag-prod-card .p-icon{font-size:44px;display:block;margin-bottom:16px}
.bag-prod-card h4{font-family:'Playfair Display',serif;font-size:18px;color:#0d3d0d;margin-bottom:10px;font-weight:700}
.bag-prod-card p{font-size:13.5px;color:#4a6a4a;line-height:1.7}

/* WHY CHOOSE */
.bag-why{background:linear-gradient(135deg,#cc2222 0%,#991111 100%);padding:64px 40px}
.bag-why-inner{max-width:1100px;margin:0 auto}
.bag-why h2{font-family:'Playfair Display',serif;font-size:clamp(24px,3vw,36px);color:#fff;text-align:center;margin-bottom:14px;font-weight:700}
.bag-why-sub{text-align:center;color:rgba(255,255,255,0.8);font-size:15px;max-width:720px;margin:0 auto 48px;line-height:1.8}
.bag-why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px}
.bag-why-item{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:16px;padding:28px 24px;text-align:center;transition:background .3s}
.bag-why-item:hover{background:rgba(255,255,255,0.18)}
.bag-why-item .w-icon{font-size:38px;margin-bottom:14px;display:block}
.bag-why-item h4{font-size:16px;font-weight:600;color:#fff;margin-bottom:8px}
.bag-why-item p{font-size:13px;color:rgba(255,255,255,0.75);line-height:1.6}

@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}

@media(max-width:768px){
  .bag-stats{grid-template-columns:repeat(2,1fr)}
  .bag-stat:nth-child(2){border-right:none}
  .bag-stat:nth-child(3){border-right:1px solid #e8f5e8}
  .bag-intro{grid-template-columns:1fr;gap:32px}
  .bag-vm-cards{grid-template-columns:1fr}
  .bag-intro-wrap,.bag-vm,.bag-products,.bag-why{padding:48px 20px}
  .bag-hero{padding:56px 20px 64px}
}
</style>

<div class="bag-about">

  {%- for block in section.blocks -%}

    {%- if block.type == 'hero' -%}
    <!-- ===== HERO BLOCK ===== -->
    <div class="bag-hero" {{ block.shopify_attributes }}>
      {% if block.settings.badge != blank %}
        <div class="bag-badge">🌱 {{ block.settings.badge }}</div>
      {% endif %}
      <h1>
        {{ block.settings.heading_line1 }}
        {% if block.settings.heading_highlight != blank %}
          <em>{{ block.settings.heading_highlight }}</em>
        {% endif %}
        {% if block.settings.heading_line2 != blank %}
          {{ block.settings.heading_line2 }}
        {% endif %}
      </h1>
      {% if block.settings.description != blank %}
        <p class="bag-hero-desc">{{ block.settings.description }}</p>
      {% endif %}
    </div>

    {%- elsif block.type == 'stats' -%}
    <!-- ===== STATS BLOCK ===== -->
    <div class="bag-stats" {{ block.shopify_attributes }}>
      {% for i in (1..4) %}
        {% assign num_key = 'stat_' | append: i | append: '_number' %}
        {% assign lbl_key = 'stat_' | append: i | append: '_label' %}
        {% if block.settings[num_key] != blank %}
        <div class="bag-stat">
          <span class="bag-stat-num"
            data-target="{{ block.settings[num_key] | remove: '+' | remove: ',' }}"
            data-suffix="{{ block.settings[num_key] | slice: -1 }}">0</span>
          <div class="bag-stat-lbl">{{ block.settings[lbl_key] }}</div>
        </div>
        {% endif %}
      {% endfor %}
    </div>

    {%- elsif block.type == 'about_intro' -%}
    <!-- ===== ABOUT INTRO BLOCK ===== -->
    <div class="bag-intro-wrap" {{ block.shopify_attributes }}>
      <div class="bag-intro">
        <div>
          <div class="bag-intro-img-inner">
            <span class="big-icon">{{ block.settings.quote_icon }}</span>
            <blockquote>{{ block.settings.quote_text }}</blockquote>
          </div>
        </div>
        <div>
          {% if block.settings.label != blank %}<span class="bag-label">{{ block.settings.label }}</span>{% endif %}
          {% if block.settings.heading != blank %}<h2>{{ block.settings.heading }}</h2>{% endif %}
          <div class="bag-intro-body">
            {% if block.settings.para1 != blank %}<p>{{ block.settings.para1 }}</p>{% endif %}
            {% if block.settings.para2 != blank %}
              <div class="bag-divider"><div class="bag-divider-line"></div><span>🌿</span><div class="bag-divider-line"></div></div>
              <p>{{ block.settings.para2 }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    {%- elsif block.type == 'vision_mission' -%}
    <!-- ===== VISION & MISSION BLOCK ===== -->
    <div class="bag-vm" {{ block.shopify_attributes }}>
      <div class="bag-vm-inner">
        <div class="bag-vm-title">
          {{ block.settings.section_title_before }}
          <span>{{ block.settings.section_title_highlight }}</span>
        </div>
        <div class="bag-vm-cards">
          <div class="bag-vm-card">
            <span class="vm-icon">{{ block.settings.vision_icon }}</span>
            <h3>{{ block.settings.vision_title }}</h3>
            <p>{{ block.settings.vision_text }}</p>
          </div>
          <div class="bag-vm-card">
            <span class="vm-icon">{{ block.settings.mission_icon }}</span>
            <h3>{{ block.settings.mission_title }}</h3>
            <p>{{ block.settings.mission_text }}</p>
          </div>
        </div>
      </div>
    </div>

    {%- elsif block.type == 'products_we_make' -%}
    <!-- ===== PRODUCTS BLOCK ===== -->
    <div class="bag-products" {{ block.shopify_attributes }}>
      <div class="bag-prod-inner">
        <div class="bag-sec-head">
          <h2>{{ block.settings.section_heading }}</h2>
          <p>{{ block.settings.section_subtext }}</p>
          <div class="bag-line"></div>
        </div>
        <div class="bag-prod-grid">
          {% for i in (1..4) %}
            {% assign icon_key = 'prod_' | append: i | append: '_icon' %}
            {% assign title_key = 'prod_' | append: i | append: '_title' %}
            {% assign desc_key = 'prod_' | append: i | append: '_desc' %}
            {% if block.settings[title_key] != blank %}
            <div class="bag-prod-card">
              <span class="p-icon">{{ block.settings[icon_key] }}</span>
              <h4>{{ block.settings[title_key] }}</h4>
              <p>{{ block.settings[desc_key] }}</p>
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    {%- elsif block.type == 'why_choose_us' -%}
    <!-- ===== WHY CHOOSE US BLOCK ===== -->
    <div class="bag-why" {{ block.shopify_attributes }}>
      <div class="bag-why-inner">
        <h2>{{ block.settings.heading }}</h2>
        {% if block.settings.subtext != blank %}
          <p class="bag-why-sub">{{ block.settings.subtext }}</p>
        {% endif %}
        <div class="bag-why-grid">
          {% for i in (1..4) %}
            {% assign icon_key = 'why_' | append: i | append: '_icon' %}
            {% assign title_key = 'why_' | append: i | append: '_title' %}
            {% assign desc_key = 'why_' | append: i | append: '_desc' %}
            {% if block.settings[title_key] != blank %}
            <div class="bag-why-item">
              <span class="w-icon">{{ block.settings[icon_key] }}</span>
              <h4>{{ block.settings[title_key] }}</h4>
              <p>{{ block.settings[desc_key] }}</p>
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

  {%- endif -%}
  {%- endfor -%}

</div>

<script>
(function(){
  function animCount(el){
    var raw=el.getAttribute('data-target');
    var target=parseInt(raw.replace(/[^0-9]/g,''));
    var orig=el.parentElement.querySelector ? el : el;
    var suffix='';
    var nextSib=el.nextSibling;
    var fullText=el.getAttribute('data-suffix')||'';
    if(isNaN(target)||target===0)return;
    var dur=1800,step=target/(dur/16),cur=0;
    var t=setInterval(function(){
      cur+=step;
      if(cur>=target){cur=target;clearInterval(t);}
      var display=target>=1000?Math.floor(cur).toLocaleString('en-IN'):Math.floor(cur);
      el.textContent=display+(fullText==='+'?'+':'');
    },16);
  }
  var els=document.querySelectorAll('.bag-stat-num[data-target]');
  if('IntersectionObserver' in window){
    var obs=new IntersectionObserver(function(entries){
      entries.forEach(function(e){if(e.isIntersecting){animCount(e.target);obs.unobserve(e.target);}});
    },{threshold:0.5});
    els.forEach(function(e){obs.observe(e);});
  } else {
    els.forEach(animCount);
  }
})();
</script>

