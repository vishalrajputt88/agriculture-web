<style>
@import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600&display=swap');

.pti-info-wrapper {
  max-width: 1440px;
  margin: 0 auto;
  padding: 28px 20px;
  font-family: 'Sora', sans-serif;
}

.pti-info-box {
  background: #FFFFFF;
  border: 0.5px solid #D4E8D2;
  border-radius: 16px;
  padding: 24px 28px;
  font-size: 14px;
  line-height: 1.75;
  color: #4A6048;
}

.pti-info-box h2,
.pti-info-box h3 {
  color: #1A2E1A;
  margin: 14px 0 8px;
}

.pti-info-box p { margin-bottom: 10px; }
.pti-info-box ul,
.pti-info-box ol { padding-left: 20px; margin-bottom: 10px; }
.pti-info-box li { margin-bottom: 5px; }
.pti-info-box strong { color: #1A2E1A; font-weight: 600; }
