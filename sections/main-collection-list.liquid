{% comment %}
  Right Shift — Shift Shop Page (FULLY DYNAMIC — No Page Refresh)
  sections/rs-shift-shop.liquid
{% endcomment %}

{%- liquid
  assign c1  = section.settings.card_color_1
  assign c2  = section.settings.card_color_2
  assign c3  = section.settings.card_color_3
  assign ppr = section.settings.products_per_row
-%}

{%- comment -%} Pre-embed all collection data for JS {%- endcomment -%}
<script>
window.rsShopData = {
  
  defaultBgImgMobile: {% if section.settings.hero_bg_image_mobile != blank %}{{ section.settings.hero_bg_image_mobile | image_url: width: 800 | json }}{% elsif section.settings.hero_bg_image != blank %}{{ section.settings.hero_bg_image | image_url: width: 800 | json }}{% else %}null{% endif %},
  defaultTitle:      {{ section.settings.hero_heading | default: 'The shift shop' | json }},
  defaultDesc:       {{ section.settings.hero_description | default: '' | json }},
  defaultBgImg:      {% if section.settings.hero_bg_image != blank %}{{ section.settings.hero_bg_image | image_url: width: 1600 | json }}{% else %}null{% endif %},
  defaultProductImg: null,
  cardColors:        [{{ c1 | json }}, {{ c2 | json }}, {{ c3 | json }}],
  ppr:               {{ ppr }},
  singlePpr:         {{ section.settings.single_products_per_row }},
  atcBg:             {{ section.settings.atc_bg | json }},
  atcColor:          {{ section.settings.atc_color | json }},
  buyBg:             {{ section.settings.buy_bg | json }},
  buyColor:          {{ section.settings.buy_color | json }},
  cardRadius:        {{ section.settings.card_radius }},
  cardGap:           {{ section.settings.card_gap }},
  titleColor:        {{ section.settings.product_title_color | json }},
  descColor:         {{ section.settings.product_desc_color | json }},
  priceColor:        {{ section.settings.price_color | json }},
  singleHeading:     {{ section.settings.single_col_heading | default: 'A variety to choose from' | json }},
  singleSubheading:  {{ section.settings.single_col_subheading | default: '' | json }},
  heroBgOpacity:     {{ section.settings.hero_bg_opacity | divided_by: 100.0 }},
  heroImgWidth:      {{ section.settings.hero_img_width }},
  collections: {
    {% for block in section.blocks %}
      {% if block.type == 'nav_icon' and block.settings.nav_collection != blank %}
        {%- assign col = block.settings.nav_collection -%}
        {%- assign col_meta_img         = col.metafields.custom.banner_image.value -%}
        {%- assign col_meta_img_mobile  = col.metafields.custom.collection_banner_mobile.value -%}
        {%- assign col_meta_desc        = col.metafields.custom.banner_description -%}

        {%- comment -%}
          Banner priority (desktop):
            1. Block image picker  (banner_desktop)
            2. Collection metafield (custom.banner_image)
            3. Collection image
            4. null
          Banner priority (mobile):
            1. Block image picker  (banner_mobile)
            2. Block image picker  (banner_desktop — fallback)
            3. Collection metafield mobile
            4. Collection metafield desktop
            5. Collection image
            6. null
        {%- endcomment -%}

        {{ col.handle | json }}: {
          title:      {{ col.title | json }},
          description: {% if col_meta_desc != blank %}{{ col_meta_desc | json }}{% else %}{{ section.settings.hero_description | json }}{% endif %},
          bannerImg:  {% if block.settings.banner_desktop != blank %}{{ block.settings.banner_desktop | image_url: width: 1600 | json }}{% elsif col_meta_img != blank %}{{ col_meta_img | image_url: width: 1600 | json }}{% elsif col.image != blank %}{{ col.image | image_url: width: 1600 | json }}{% else %}null{% endif %},
          bannerImgMobile: {% if block.settings.banner_mobile != blank %}{{ block.settings.banner_mobile | image_url: width: 800 | json }}{% elsif block.settings.banner_desktop != blank %}{{ block.settings.banner_desktop | image_url: width: 800 | json }}{% elsif col_meta_img_mobile != blank %}{{ col_meta_img_mobile | image_url: width: 800 | json }}{% elsif col_meta_img != blank %}{{ col_meta_img | image_url: width: 800 | json }}{% elsif col.image != blank %}{{ col.image | image_url: width: 800 | json }}{% else %}null{% endif %},
          productImg: {% if col.image != blank %}{{ col.image | image_url: width: 600 | json }}{% else %}null{% endif %}
        },
      {% endif %}
    {% endfor %}
  }
};
</script>

{%- comment -%}══════════ CSS CUSTOM PROPERTIES ══════════{%- endcomment -%}
<style>
  /* ── Section-scoped design tokens ── */
  #rs-section-{{ section.id }} {
    --rs-c1:             {{ c1 }};
    --rs-c2:             {{ c2 }};
    --rs-c3:             {{ c3 }};
    --rs-hero-bg:        {{ section.settings.hero_bg_color }};
    --rs-hero-h:         {{ section.settings.hero_height }}px;
    --rs-hero-heading-c: {{ section.settings.hero_heading_color }};
    --rs-hero-heading-s: {{ section.settings.hero_heading_size }}px;
    --rs-hero-desc-c:    {{ section.settings.hero_desc_color }};
    --rs-hero-desc-s:    {{ section.settings.hero_desc_size }}px;
    --rs-hero-img-w:     {{ section.settings.hero_img_width }}px;
    --rs-hero-pv:        {{ section.settings.hero_padding_v }}px;
    --rs-hero-ph:        {{ section.settings.hero_padding_h }}px;
    --rs-hero-bg-op:     {{ section.settings.hero_bg_opacity | divided_by: 100.0 }};
    --rs-icons-bg:       {{ section.settings.icons_bg }};
    --rs-icons-pad:      {{ section.settings.icons_padding }}px;
    --rs-icons-gap:      {{ section.settings.icons_gap }}px;
    --rs-icons-align:    {{ section.settings.icons_align }};
    --rs-icon-sz:        {{ section.settings.icon_size }}px;
    --rs-icon-bdr:       {{ section.settings.icon_border }}px;
    --rs-icon-item-w:    {{ section.settings.icon_item_width }}px;
    --rs-icon-label-c:   {{ section.settings.icon_label_color }};
    --rs-icon-label-s:   {{ section.settings.icon_label_size }}px;
    --rs-all-icon-bg:    {{ section.settings.all_icon_bg }};
    --rs-all-icon-bdr:   {{ section.settings.all_icon_border_color }};
    --rs-crumb-c:        {{ section.settings.breadcrumb_color }};
    --rs-section-pt:     {{ section.settings.section_pt }}px;
    --rs-section-pb:     {{ section.settings.section_pb }}px;
    --rs-row-h-c:        {{ section.settings.row_heading_color }};
    --rs-row-h-s:        {{ section.settings.row_heading_size }}px;
    --rs-row-sub-c:      {{ section.settings.row_sub_color }};
    --rs-row-gap:        {{ section.settings.row_gap }}px;
    --rs-card-gap:       {{ section.settings.card_gap }}px;
    --rs-card-r:         {{ section.settings.card_radius }}px;
    --rs-title-c:        {{ section.settings.product_title_color }};
    --rs-desc-c:         {{ section.settings.product_desc_color }};
    --rs-price-c:        {{ section.settings.price_color }};
    --rs-atc-bg:         {{ section.settings.atc_bg }};
    --rs-atc-c:          {{ section.settings.atc_color }};
    --rs-buy-bg:         {{ section.settings.buy_bg }};
    --rs-buy-c:          {{ section.settings.buy_color }};
    --rs-arrow-bg:       {{ section.settings.arrow_bg }};
    --rs-arrow-c:        {{ section.settings.arrow_color }};
    --rs-ppr:            {{ ppr }};
    --rs-single-ppr:     {{ section.settings.single_products_per_row }};
    --rs-faq-bg:         {{ section.settings.faq_bg }};
    --rs-faq-h-c:        {{ section.settings.faq_heading_color }};
    --rs-faq-h-s:        {{ section.settings.faq_heading_size }}px;
    --rs-faq-div:        {{ section.settings.faq_divider }};
    --rs-faq-q-c:        {{ section.settings.faq_q_color }};
    --rs-faq-q-s:        {{ section.settings.faq_q_size }}px;
    --rs-faq-a-c:        {{ section.settings.faq_a_color }};
    --rs-faq-a-s:        {{ section.settings.faq_a_size }}px;
    --rs-faq-icon-c:     {{ section.settings.faq_icon_color }};
    --rs-faq-item-pad:   {{ section.settings.faq_item_pad }}px;
    --rs-faq-img-w:      {{ section.settings.faq_img_width }}px;
    --rs-faq-img-r:      {{ section.settings.faq_img_radius }}px;
    --rs-faq-pt:         {{ section.settings.faq_pt }}px;
    --rs-faq-pb:         {{ section.settings.faq_pb }}px;
  }


  #rs-section-template--21783715021036__rs_shift_shop_Wn99qH .rs-hero { min-height: 637px; }

  /* ══════════════════════════════
   FLYING HEART ANIMATION
══════════════════════════════ */
.rs-fly-heart {
  position: fixed;
  pointer-events: none;
  z-index: 99999;
  font-size: 22px;
  color: #e53e3e;
  animation: rsFlyToWishlist 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  will-change: transform, opacity;
}
@keyframes rsFlyToWishlist {
  0%   { transform: scale(1) translate(0, 0);     opacity: 1; }
  60%  { transform: scale(1.4) translate(var(--fly-x), var(--fly-y)); opacity: 1; }
  100% { transform: scale(0.3) translate(var(--fly-x2), var(--fly-y2)); opacity: 0; }
}

/* ══════════════════════════════
   ADD TO CART — PARTICLE BURST
══════════════════════════════ */
.rs-particle {
  position: fixed;
  pointer-events: none;
  z-index: 99999;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  animation: rsParticleBurst 0.7s ease-out forwards;
  will-change: transform, opacity;
}
@keyframes rsParticleBurst {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(var(--px), var(--py)) scale(0); opacity: 0; }
}

/* ATC Button flash */
.rs-btn-atc.rs-atc-flash {
  animation: rsAtcFlash 0.4s ease;
}
@keyframes rsAtcFlash {
  0%   { transform: scale(1); }
  30%  { transform: scale(0.92); filter: brightness(1.3); }
  60%  { transform: scale(1.06); }
  100% { transform: scale(1); }
}

/* Wishlist button pulse */
.rs-wishlist-toggle.rs-wl-pulse {
  animation: rsWlPulse 0.4s ease;
}
@keyframes rsWlPulse {
  0%   { transform: scale(1); }
  40%  { transform: scale(1.5); }
  100% { transform: scale(1); }
}
</style>



{% assign is_wishlisted = false %}
{%- comment -%}══════════ HERO ══════════{%- endcomment -%}
<div id="rs-section-{{ section.id }}" class="rs-section">

<div id="rs-hero" class="rs-hero">
  <div id="rs-hero-bg" class="rs-hero-bg">
    <img id="rs-hero-bg-img" src="" alt="" class="rs-hero-bg-img">
    <img id="rs-hero-bg-img-mobile" src="" alt="" class="rs-hero-bg-img rs-hero-bg-img--mobile">
  </div>
</div>


{%- comment -%}══════════ ICONS ROW ══════════{%- endcomment -%}
{% if section.settings.show_icons_row %}
<div class="rs-icons-row">
  <div class="rs-icons-wrap">

    {%- comment -%} Shop All button {%- endcomment -%}
    <button class="rs-nav-icon rs-nav-active" onclick="rsShowDefault(this)" aria-label="Shop All">
      <div class="rs-nav-circle rs-nav-circle--all">
        {% if section.settings.all_icon_image != blank %}
          <img src="{{ section.settings.all_icon_image | image_url: width: 160 }}" alt="Shop All" class="rs-icon-img">
        {% else %}
          <span class="rs-icon-emoji">🛒</span>
        {% endif %}
      </div>
      <span class="rs-icon-label">{{ section.settings.all_icon_label | default: 'Shop all' }}</span>
    </button>

    {%- comment -%} Collection icons {%- endcomment -%}
    {% for block in section.blocks %}
      {% if block.type == 'nav_icon' %}
        {%- assign col = block.settings.nav_collection -%}
        {%- assign col_handle = col.handle | default: '' -%}
        <button class="rs-nav-icon" onclick="rsSelectCollection(this)"
          data-handle="{{ col_handle }}"
          data-label="{{ block.settings.icon_label | escape }}"
          aria-label="{{ block.settings.icon_label | escape }}"
          style="--rs-this-icon-bg: {{ block.settings.icon_bg }}; --rs-this-icon-bdr: {{ block.settings.icon_border_color }};"
          {{ block.shopify_attributes }}>
          <div class="rs-nav-circle rs-nav-circle--col">
            {% if block.settings.icon_image != blank %}
              <img src="{{ block.settings.icon_image | image_url: width: 160 }}" alt="{{ block.settings.icon_label }}" class="rs-icon-img">
            {% elsif col != blank and col.image != blank %}
              <img src="{{ col.image | image_url: width: 160 }}" alt="{{ block.settings.icon_label }}" class="rs-icon-img">
            {% endif %}
          </div>
          <span class="rs-icon-label">{{ block.settings.icon_label }}</span>
        </button>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}

<div class="rs-page-bg" {% if section.settings.page_bg != blank %}style="background-image: url('{{ section.settings.page_bg | image_url: width: 2000 }}'); background-size: cover;"{% endif %}>

{%- comment -%}══════════ BREADCRUMB ══════════{%- endcomment -%}
{% if section.settings.show_breadcrumb %}
<div class="rs-breadcrumb-wrap">
  <a href="{{ routes.root_url }}" class="rs-breadcrumb-link">Home</a>
  <span class="rs-breadcrumb-sep">›</span>
  <a href="#" class="rs-breadcrumb-link">{{ section.settings.breadcrumb_shop_text | default: 'The shift shop' }}</a>
  <span id="rs-breadcrumb-col" class="rs-hidden">
    <span class="rs-breadcrumb-sep">›</span>
    <span id="rs-breadcrumb-col-name"></span>
  </span>
</div>
{% endif %}


{%- comment -%}══════════ MAIN CONTENT ══════════{%- endcomment -%}
<div class="rs-main-content">
  <div class="rs-container">

    {%- comment -%}── PANEL A: Multi-row default ──{%- endcomment -%}
    <div id="rs-panel-multi">
      {% for block in section.blocks %}
        {% if block.type == 'product_row' %}
          {%- assign row_col   = block.settings.row_collection -%}
          {%- assign slider_id = 'rss-' | append: block.id -%}
          <div class="rs-row" {{ block.shopify_attributes }}>

            <div class="rs-row-header">
              <div class="top_collection">
                <h2 class="rs-row-heading">{{ block.settings.row_heading }}</h2>
                {% if block.settings.row_subheading != blank %}
                  <div class="rs-row-sub">
                 <div> {{ block.settings.row_subheading }}</div>
                 <div>Just so you can start your mornings on the right note.</div>

                </div>{% endif %}
              </div>
              <div class="rs-badges">
                <div class="rs_badge_inner">
                {% if block.settings.badge_grains %}<img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Added-Preservatives-1.webp?v=1773949015" alt="No Chemicals">
                <div>100% Whole Grains</div>{% endif %} </div>
                <div class="rs_badge_inner">
                {% if block.settings.badge_nutrition %}  <img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Added-Colours-1.webp?v=1773949015" alt="whole grains">  <div>Nutritionally Balanced</div>{% endif %} </div>
                <div class="rs_badge_inner">
                {% if block.settings.badge_chemicals %}<img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Trans-Fat-1_9e98ae0d-c063-4a02-b5dc-38ec9e42f827.webp?v=1773949013" alt="Nutritionally balanced"> <div>No Chemicals</div>{% endif %} </div>
              </div>
            </div>

            <div class="rs-slider-wrap">
              {% if section.settings.show_arrows %}
                <button class="rs-arr rs-arr--prev" onclick="rsSlider('{{ slider_id }}',-1)" aria-label="Previous">{{ 'slick-arrow.svg' | inline_asset_content }}</button>
                <button class="rs-arr rs-arr--next" onclick="rsSlider('{{ slider_id }}',1)" aria-label="Next">{{ 'slick-arrow.svg' | inline_asset_content }}</button>
              {% endif %}

              {%- comment -%} Scrollable viewport with peek effect {%- endcomment -%}
              <div class="rs-slider-viewport">
                <div id="{{ slider_id }}" class="rs-slider-track" data-page="0" data-ppr="{{ ppr }}">
                  {%- assign pi = 0 -%}
                  {% if row_col != blank %}
                    {% for product in row_col.products limit: 50 %}
                      {%- assign ci = pi | modulo: 3 -%}
                      {%- assign pi = pi | plus: 1 -%}
                      {%- if ci == 0 -%}{%- assign cbg = c1 -%}{%- elsif ci == 1 -%}{%- assign cbg = c2 -%}{%- else -%}{%- assign cbg = c3 -%}{%- endif -%}
                      <div class="rs-card rs-card--c{{ ci | plus: 1 }}" style="--rs-card-cbg: {{ cbg }};">
                        <div class="rs-card-inner">
                          <a href="{{ product.url }}" class="rs-card-img-link">
                            {% if product.featured_image != blank %}
                              <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="lazy" class="rs-cimg">
                            {% else %}
                              <div class="rs-card-no-img">No Image</div>
                            {% endif %}
                          </a>
                          <button
  class="rs-wishlist-toggle"
  id="rs-wl-btn"
  data-handle="{{ product.handle }}"
  aria-label="Add to Wishlist"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
  </svg>
</button>
                          <div class="rs-card-btns">
                            <button onclick="rsATC('{{ product.variants.first.id }}',this)" class="rs-btn-atc">Add to cart</button>
                            <a href="{{ product.url }}?buy=true" class="rs-btn-buy">Buy now</a>
                          </div>
                        </div>
                        <div class="rs-card-body">
                          <p class="rs-card-title"><a href="{{ product.url }}" class="rs-card-title-link">{{ product.title }}</a></p>
                          {% if product.description != blank %}<p class="rs-card-desc">{{ product.description | strip_html | truncate: 80 }}</p>{% endif %}
                          <div class="rs-card-price">
                            {{ product.price | money }}
                            {% if product.compare_at_price > product.price %}<span class="rs-card-compare">{{ product.compare_at_price | money }}</span>{% endif %}
                          </div>
                        </div>
                      </div>
                    {% endfor %}
                  {% else %}
                    {% for i in (1..ppr) %}
                      {%- assign ci = forloop.index0 | modulo: 3 -%}
                      {%- if ci == 0 -%}{%- assign cbg = c1 -%}{%- elsif ci == 1 -%}{%- assign cbg = c2 -%}{%- else -%}{%- assign cbg = c3 -%}{%- endif -%}
                      <div class="rs-card rs-card-placeholder rs-card--c{{ ci | plus: 1 }}" style="--rs-card-cbg: {{ cbg }};">
                         <button
  class="rs-wishlist-toggle"
  id="rs-wl-btn"
  data-handle="{{ product.handle }}"
  aria-label="Add to Wishlist"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
  </svg>
  <span>Add to Wishlist</span>
</button>
                        <div class="rs-card-inner">
                          <div class="rs-card-no-img">Assign collection in editor</div>
                          <div class="rs-card-btns"><div class="rs-btn-atc">Add to cart</div><div class="rs-btn-buy">Buy now</div></div>
                        </div>
                        <div class="rs-card-body">
                          <div class="rs-skel-line rs-skel-line--lg"></div>
                          <div class="rs-skel-line rs-skel-line--sm"></div>
                        </div>
                      </div>
                    {% endfor %}
                  {% endif %}
                </div>
              </div>
            </div>

          </div>
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%}── PANEL B: Single collection ──{%- endcomment -%}
    <div id="rs-panel-single" class="rs-hidden">
      <div class="rs-row-header">
        <div class="top_collection">
          <h2 id="rs-single-heading" class="rs-row-heading">{{ section.settings.single_col_heading | default: 'A variety to choose from' }}</h2>
          <p id="rs-single-subheading" class="rs-row-sub">{{ section.settings.single_col_subheading }}</p>
        </div>
        <div class="rs-badges"> 
          <div>
          {% if section.settings.single_badge_grains %}<img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Trans-Fat-1_9e98ae0d-c063-4a02-b5dc-38ec9e42f827.webp?v=1773949013" alt="No Chemicals"><span > 100% Whole Grains</span>{% endif %} </div>
          <div>
          {% if section.settings.single_badge_nutrition %}<img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Added-Colours-1.webp?v=1773949015" alt="whole grains"> <span>Nutritionally Balanced</span>{% endif %} </div>
          <div>
          {% if section.settings.single_badge_chemicals %}<img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Trans-Fat-1_9e98ae0d-c063-4a02-b5dc-38ec9e42f827.webp?v=1773949013" alt="Nutritionally balanced"><span> No Chemicals</span>{% endif %} </div>
        </div>
      </div>

      {%- comment -%} SHIMMER SKELETON LOADER {%- endcomment -%}
      <div id="rs-single-loader" class="rs-single-grid rs-hidden">
        {%- assign sk_total = section.settings.single_products_per_row | times: 2 -%}
        {% for i in (1..sk_total) %}
          {%- assign ci = forloop.index0 | modulo: 3 -%}
          {%- if ci == 0 -%}{%- assign cbg = c1 -%}{%- elsif ci == 1 -%}{%- assign cbg = c2 -%}{%- else -%}{%- assign cbg = c3 -%}{%- endif -%}
          <div class="rs-sk-card" style="--rs-card-cbg: {{ cbg }};">
            <div class="rs-sk-img">
              <div class="rs-shimmer"></div>
            </div>
             <button
  class="rs-wishlist-toggle"
  id="rs-wl-btn"
  data-handle="{{ product.handle }}"
  aria-label="Add to Wishlist"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
  </svg>
  <span>Add to Wishlist</span>
</button>
            <div class="rs-card-btns">
              <div class="rs-btn-atc rs-sk-btn"><div class="rs-shimmer rs-shimmer-dark"></div></div>
              <div class="rs-btn-buy rs-sk-btn"><div class="rs-shimmer rs-shimmer-light"></div></div>
            </div>
            <div class="rs-sk-body">
              <div class="rs-skel-line rs-skel-line--lg"><div class="rs-shimmer"></div></div>
