    { "type": "color",    "id": "breadcrumb_color",     "label": "Breadcrumb Color",          "default": "#2d2119" },

    { "type": "header", "content": "📦 Products & Cards (Panel A — Shop All view)" },
    { "type": "range",  "id": "section_pt",          "label": "Section Padding Top",     "min": 0, "max": 80, "step": 4, "default": 40, "unit": "px" },
