  #rs-single-grid .rs-card:nth-child(2) { animation-delay: .09s; }
  #rs-single-grid .rs-card:nth-child(3) { animation-delay: .14s; }
  #rs-single-grid .rs-card:nth-child(4) { animation-delay: .19s; }
  #rs-single-grid .rs-card:nth-child(5) { animation-delay: .24s; }
  #rs-single-grid .rs-card:nth-child(6) { animation-delay: .29s; }
  #rs-single-grid .rs-card:nth-child(n+7) { animation-delay: .34s; }

  @keyframes rsFadeUp {
