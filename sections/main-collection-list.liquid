    .rs-faq-heading  { font-size: 20px; }
    .rs-faq-q        { font-size: 13px; }
    .rs-wishlist-toggle svg { width: 20px; height: 20px; }
    .rs-card-desc    { font-size: 12px; }
    .rs-breadcrumb-wrap  { padding-left: 20px; padding-bottom: 0; }
    .rs-row-sub      { font-size: 15px; margin-top: 20px; }
