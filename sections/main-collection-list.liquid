{%- comment -%} ══════════ COMPONENT STYLES ══════════ {%- endcomment -%}
<style>

  /* ── Utilities ── */
  .rs-hidden { display: none !important; }
  .rs-badges .rs_badge_inner {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }
  .rs-badges .rs_badge_inner { font-size: 17px; }

  /* ── Hero ── */
  .rs-hero {
    background-color: var(--rs-hero-bg);
    min-height: var(--rs-hero-h);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    transition: background-color .4s;
  }
  .rs-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .rs-hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
    opacity: var(--rs-hero-bg-op);
  }
  .rs-hero-bg-img--visible { display: block; }

  /* ── Icons Row ── */
  .rs-icons-row {
    background-color: var(--rs-icons-bg);
    padding: var(--rs-icons-pad) var(--rs-hero-ph);
  }
  .rs-icons-wrap {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: var(--rs-icons-align);
    gap: var(--rs-icons-gap);
    align-items: flex-start;
  }
  .rs-nav-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .rs-nav-circle {
    width: var(--rs-icon-sz);
    height: var(--rs-icon-sz);
    border-radius: 50%;
    overflow: hidden;
    border-width: var(--rs-icon-bdr);
    border-style: solid;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .2s, box-shadow .2s;
  }
  .rs-nav-circle--all {
    background: var(--rs-all-icon-bg);
    border-color: var(--rs-all-icon-bdr);
  }
  .rs-nav-circle--col {
    background: var(--rs-this-icon-bg, #e8f5e9);
    border-color: var(--rs-this-icon-bdr, #4caf50);
  }
  .rs-icon-img   { width: 100%; height: 100%; object-fit: cover; display: block; }
  .rs-icon-emoji { font-size: 24px; }
  .rs-icon-label {
    color: var(--rs-icon-label-c);
    font-size: var(--rs-icon-label-s);
    text-align: center;
    line-height: 1.3;
    font-family: 'Paytone One', sans-serif;
    margin-top: 5px;
  }
  .rs-nav-icon:hover .rs-nav-circle { transform: scale(1.1); }
  .rs-nav-active .rs-nav-circle { outline: 3px solid #fff; outline-offset: 0; }

  /* ── Breadcrumb ── */
  .rs-breadcrumb-wrap {
    max-width: 1470px;
    margin: 0 auto;
    padding: 10px var(--rs-hero-ph);
    font-size: 18px;
    color: var(--rs-crumb-c);
  }
  .rs-breadcrumb-link { color: var(--rs-crumb-c); text-decoration: none; }
  .rs-breadcrumb-sep  { margin: 0 5px; }

  /* ── Main Content ── */
  .rs-main-content { padding: var(--rs-section-pt) 0 var(--rs-section-pb); }
  .rs-container    { max-width: 1470px; margin: 0 auto; padding: 0 var(--rs-hero-ph); }

  /* ── Product Row (Panel A) ── */
  .rs-row       { margin-bottom: var(--rs-row-gap); }
  .rs-row-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
  }
  .rs-row-heading {
    color: var(--rs-row-h-c);
    font-size: var(--rs-row-h-s);
    margin: 0 0 4px;
    line-height: 1.2;
  }
  .rs-row-sub { color: var(--rs-row-sub-c); font-size: 20px; margin: 0; line-height: 1.4; }

  /* ── Quality Badges ── */
  .rs-badges { display: flex; gap: 30px; flex-wrap: wrap; align-items: center; }
