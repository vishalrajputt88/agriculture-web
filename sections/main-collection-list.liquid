  .rs-card-btns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }
  .rs-btn-atc {
    background: var(--rs-atc-bg);
    color: var(--rs-atc-c);
    border: none;
    padding: 6px 8px;
    font-size: 23px;
    font-weight: 700;
    cursor: pointer;
    text-align: center;
  }
  .rs-btn-buy {
    background: var(--rs-buy-bg);
    color: var(--rs-buy-c);
    padding: 6px 8px;
    font-size: 23px;
    font-weight: 700;
    text-decoration: none;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rs-card-body  { padding: 12px 0 16px; flex: 1; }
  .rs-card-title {
    color: var(--rs-title-c);
    font-size: 19px;
    margin: 0 0 5px;
    line-height: 1.35;
    font-weight: 600;
  }
  .rs-card-title-link  { color: inherit; text-decoration: none; }
  .rs-card-desc {
    color: var(--rs-desc-c);
    font-size: 19px;
    margin: 0 0 8px;
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .rs-card-price   { color: var(--rs-price-c); font-size: 24px; font-weight: 800; }
  .rs-card-compare { color: #aaa; font-size: 12px; font-weight: 400; text-decoration: line-through; margin-left: 4px; }

  /* Product card buttons larger in multi-row panel */
  #rs-panel-multi .rs-btn-atc,
  #rs-panel-multi .rs-btn-buy { font-size: 23px; }

  /* Wishlist toggle button */
  .rs-wishlist-toggle svg { width: 30px; height: 30px; }
  .rs-wishlist-toggle {
    position: absolute;
    right: 10px; top: 10px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    border-radius: 8px;
    padding: 10px 16px;
    cursor: pointer;
    font-size: 0.9rem;
    color: #175c2e;
