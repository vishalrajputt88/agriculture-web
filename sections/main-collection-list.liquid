  /* Prev / Next arrows */
  .rs-arr {
    position: absolute;
    top: 38%;
    transform: translateY(-50%);
    z-index: 10;
    background: transparent;
    color: var(--rs-arrow-c);
    border: none;
    width: 42px; height: 42px;
    border-radius: 50%;
    font-size: 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: opacity .2s;
  }
  .rs-arr:hover        { opacity: .8; }
  .rs-arr--prev        { left: -80px; }
  .rs-arr--next        { right: -80px; rotate: 180deg; top: 28%; }
  .rs-arr--hidden      { opacity: .3; pointer-events: none; }

  /* ── Product Cards (Panel A — product_row sliders) ── */
  .rs-card {
    border-radius: var(--rs-card-r);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: transparent;
  }
  .rs-card-inner {
    border-radius: var(--rs-card-r);
    overflow: hidden;
    background: var(--rs-card-cbg);
    position: relative;
  }
  .rs-card-img-link {
    display: block;
    overflow: hidden;
