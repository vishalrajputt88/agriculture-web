  .rs-faq-img-wrap        { flex-shrink: 0; width: var(--rs-faq-img-w); max-width: 100%; }
  .rs-faq-img             { width: 100%; height: auto; display: block; border-radius: var(--rs-faq-img-r); }

  /* ── Hero BG — desktop vs mobile ── */
  .rs-hero-bg-img--mobile { display: none !important; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .rs-arr--next    { right: 2px; top: 13% !important; }
    .rs-arr--prev    { left: 0; }
