  .rs-single-grid {
    display: grid;
    grid-template-columns: repeat(var(--rs-single-ppr), 1fr);
    gap: var(--rs-card-gap);
  }

  /* Collection card — "Explore →" button spans full width */
  .rs-col-card .rs-card-btns {
    grid-template-columns: 1fr;
  }
  .rs-col-explore {
    font-size: 16px !important;
    font-weight: 700;
    letter-spacing: 0.5px;
    grid-column: 1 / -1;
  }

  /* Smaller text in single/category panel */
  #rs-panel-single .rs-card-title { font-size: 14px; }
  #rs-panel-single .rs-card-price { font-size: 15px; }
  #rs-panel-single .rs-card-body  { padding: 12px 14px 16px; }
  #rs-panel-single .rs-cimg       { aspect-ratio: 4/3; object-fit: cover; padding: 0; }

