    { "type": "color",       "id": "all_icon_border_color","label": "Shop All Border Color",     "default": "#e0c97a" },
    { "type": "header", "content": "🍞 Breadcrumb" },
    { "type": "checkbox",    "id": "show_breadcrumb",      "label": "Show Breadcrumb",           "default": true },
    { "type": "text",        "id": "breadcrumb_shop_text", "label": "Shop Label",                "default": "The shift shop" },
    { "type": "text",        "id": "shop_page_handle",     "label": "Shop Page Handle",          "default": "shift-shop" },
    { "type": "color",       "id": "breadcrumb_color",     "label": "Breadcrumb Color",          "default": "#2D2119" },
    { "type": "header", "content": "📦 Products & Cards" },
