{% comment %}
  Right Shift — Agriculture Shop Page  (FULLY DYNAMIC — No Page Refresh)
  sections/rs-agri-shop.liquid

  ─────────────────────────────────────────────────────────────
  LAYOUT OVERVIEW
  ─────────────────────────────────────────────────────────────
  1. Hero Banner        — Updates dynamically when a category is selected
  2. Icons Row          — Main agriculture categories (Seeds, Pesticides, etc.)
  3. Default View       — Multi-row product sliders (product_row blocks)
  4. Category View      — Grid of sub-collections inside the clicked category
  ─────────────────────────────────────────────────────────────

  HOW NESTED COLLECTIONS WORK
  ─────────────────────────────────────────────────────────────
  Step 1 → Add a "Nav Icon" block  →  assign a parent collection (e.g. "seeds")
  Step 2 → Add "Sub-Collection Card" blocks
           Set "Parent Category Handle" = handle of the parent nav collection
           Pick the sub-collection (e.g. "tomato-seeds", "wheat-seeds", etc.)
  Step 3 → When a user clicks the nav icon, the sub-collection cards appear
           Clicking a card navigates to /collections/{handle}
  ─────────────────────────────────────────────────────────────

  BLOCK TYPES
  ─────────────────────────────────────────────────────────────
  nav_icon            — Navigation circle icon (main category)
  sub_collection_card — Sub-category card shown under a nav_icon
  product_row         — Horizontal product slider in the default (Shop All) view
  faq_item            — FAQ accordion entry
  ─────────────────────────────────────────────────────────────
{% endcomment %}

{%- liquid
  assign c1  = section.settings.card_color_1
  assign c2  = section.settings.card_color_2
  assign c3  = section.settings.card_color_3
  assign ppr = section.settings.products_per_row
-%}

{%- comment -%} ── Pre-embed all data for JS so no extra network requests are needed ── {%- endcomment -%}
<script>
window.rsShopData = {

  /* ── Default hero content (shown on "Shop All" / page load) ── */
  defaultBgImgMobile: {% if section.settings.hero_bg_image_mobile != blank %}{{ section.settings.hero_bg_image_mobile | image_url: width: 800 | json }}{% elsif section.settings.hero_bg_image != blank %}{{ section.settings.hero_bg_image | image_url: width: 800 | json }}{% else %}null{% endif %},
  defaultTitle:       {{ section.settings.hero_heading | default: 'Agriculture Solutions' | json }},
  defaultDesc:        {{ section.settings.hero_description | default: '' | json }},
  defaultBgImg:       {% if section.settings.hero_bg_image != blank %}{{ section.settings.hero_bg_image | image_url: width: 1600 | json }}{% else %}null{% endif %},
  defaultProductImg:  null,

  /* ── Card colors (rotate: Color1 → Color2 → Color3) ── */
  cardColors: [{{ c1 | json }}, {{ c2 | json }}, {{ c3 | json }}],

  /* ── Layout settings (passed to JS to avoid re-reading CSS) ── */
  ppr:            {{ ppr }},
  singlePpr:      {{ section.settings.single_products_per_row }},
  atcBg:          {{ section.settings.atc_bg | json }},
  atcColor:       {{ section.settings.atc_color | json }},
  buyBg:          {{ section.settings.buy_bg | json }},
  buyColor:       {{ section.settings.buy_color | json }},
  cardRadius:     {{ section.settings.card_radius }},
  cardGap:        {{ section.settings.card_gap }},
  titleColor:     {{ section.settings.product_title_color | json }},
  descColor:      {{ section.settings.product_desc_color | json }},
  priceColor:     {{ section.settings.price_color | json }},
  singleHeading:  {{ section.settings.single_col_heading | default: 'Select a Category' | json }},
  singleSubheading: {{ section.settings.single_col_subheading | default: '' | json }},
  heroBgOpacity:  {{ section.settings.hero_bg_opacity | divided_by: 100.0 }},
  heroImgWidth:   {{ section.settings.hero_img_width }},

  /* ── Per-category hero banner data (keyed by collection handle) ── */
  collections: {
    {% for block in section.blocks %}
      {% if block.type == 'nav_icon' and block.settings.nav_collection != blank %}
        {%- assign col             = block.settings.nav_collection -%}
        {%- assign col_meta_img    = col.metafields.custom.banner_image.value -%}
        {%- assign col_meta_img_m  = col.metafields.custom.collection_banner_mobile.value -%}
        {%- assign col_meta_desc   = col.metafields.custom.banner_description -%}

        {%- comment -%}
          Desktop banner priority:
            1. Block image picker (banner_desktop)
            2. Collection metafield (custom.banner_image)
            3. Collection image
            4. null

          Mobile banner priority:
            1. Block image picker (banner_mobile)
            2. Block image picker (banner_desktop — fallback)
            3. Collection metafield mobile
            4. Collection metafield desktop
            5. Collection image
            6. null
        {%- endcomment -%}

        {{ col.handle | json }}: {
          title:          {{ col.title | json }},
          description:    {% if col_meta_desc != blank %}{{ col_meta_desc | json }}{% else %}{{ section.settings.hero_description | json }}{% endif %},
          bannerImg:      {% if block.settings.banner_desktop != blank %}{{ block.settings.banner_desktop | image_url: width: 1600 | json }}{% elsif col_meta_img != blank %}{{ col_meta_img | image_url: width: 1600 | json }}{% elsif col.image != blank %}{{ col.image | image_url: width: 1600 | json }}{% else %}null{% endif %},
          bannerImgMobile:{% if block.settings.banner_mobile != blank %}{{ block.settings.banner_mobile | image_url: width: 800 | json }}{% elsif block.settings.banner_desktop != blank %}{{ block.settings.banner_desktop | image_url: width: 800 | json }}{% elsif col_meta_img_m != blank %}{{ col_meta_img_m | image_url: width: 800 | json }}{% elsif col_meta_img != blank %}{{ col_meta_img | image_url: width: 800 | json }}{% elsif col.image != blank %}{{ col.image | image_url: width: 800 | json }}{% else %}null{% endif %},
          productImg:     {% if col.image != blank %}{{ col.image | image_url: width: 600 | json }}{% else %}null{% endif %}
        },
      {% endif %}
    {% endfor %}
  },

  /* ── Sub-collection data — keyed by parent nav collection handle ──
     Built at render time; no API fetch needed when user clicks a nav icon.
     Each entry is an array of sub-collection card objects.              ── */
  subCollections: {
    {% for nav_block in section.blocks %}
      {% if nav_block.type == 'nav_icon' and nav_block.settings.nav_collection != blank %}
        {%- assign nav_handle = nav_block.settings.nav_collection.handle -%}
        {{ nav_handle | json }}: [
          {% for sub_block in section.blocks %}
            {% if sub_block.type == 'sub_collection_card' %}
              {%- assign sub_parent = sub_block.settings.parent_handle | downcase | strip -%}
              {%- assign nav_h      = nav_handle | downcase | strip -%}
              {% if sub_parent == nav_h %}
                {%- assign sc = sub_block.settings.sub_collection -%}
                {
                  handle: {{ sc.handle | default: '' | json }},
                  title:  {% if sub_block.settings.card_label != blank %}{{ sub_block.settings.card_label | json }}{% else %}{{ sc.title | json }}{% endif %},
                  desc:   {% if sub_block.settings.card_desc != blank %}{{ sub_block.settings.card_desc | json }}{% elsif sc.description != blank %}{{ sc.description | strip_html | truncate: 100 | json }}{% else %}null{% endif %},
                  img:    {% if sub_block.settings.card_image != blank %}{{ sub_block.settings.card_image | image_url: width: 500 | json }}{% elsif sc.image != blank %}{{ sc.image | image_url: width: 500 | json }}{% else %}null{% endif %},
                  url:    {{ sc.url | default: '#' | json }}
                },
              {% endif %}
            {% endif %}
          {% endfor %}
        ],
      {% endif %}
    {% endfor %}
  }

};
</script>

