    .rs-container    { padding: 0 15px !important; }
    .rs-badges span  { max-width: 77px; font-size: 10px; line-height: normal; }
    .top_collection  { width: 100%; text-align: center; }
    .rs-row-heading  { font-size: 28px; }
    .rs-card-body    { text-align: center; }
    .rs-card-title   { font-size: 16px; }
    .rs-card-price   { font-size: 16px; }
    .rs-single-grid  { grid-template-columns: repeat(2, 1fr) !important; }
    #rs-panel-multi .rs-btn-atc,
    #rs-panel-multi .rs-btn-buy { font-size: 13px; }
    .rs-btn-atc, .rs-btn-buy { font-size: 13px; }
  }

  @media (max-width: 480px) {
    .rs-slider-track .rs-card { flex: 0 0 calc(48%); }
    .rs-single-grid { grid-template-columns: repeat(1, 1fr) !important; }
  }

</style>


{%- comment -%} ══════════ JAVASCRIPT ══════════ {%- endcomment -%}
<script>
(function () {

  var d = window.rsShopData;

  /* ── Cache for product API calls (Panel A slider use only) ── */
  var productCache = {};

  /* ── Format paise to ₹ with Indian number formatting ── */
  function fmtPrice(cents) {
    if (cents === null || cents === undefined) return '';
    var n = parseInt(cents, 10);
    if (isNaN(n)) return '';
    return '₹' + (n / 100).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  /* ── Replace {width} placeholder and ensure https in image URLs ── */
  function fixImg(src) {
    if (!src) return null;
    var s = src.replace(/\{width\}/g, '500');
    if (s.indexOf('//') === 0) s = 'https:' + s;
    return s;
  }

  /* ══════════════════════════════════════
     HERO — update banner image and text
  ══════════════════════════════════════ */
  function updateHero(title, desc, bgImg, productImg, bgImgMobile) {
    var bgEl       = document.getElementById('rs-hero-bg-img');
    var bgElMobile = document.getElementById('rs-hero-bg-img-mobile');

    /* Desktop banner */
    if (bgEl) {
      if (bgImg) {
        bgEl.src = bgImg;
        bgEl.classList.add('rs-hero-bg-img--visible');
      } else {
        bgEl.src = '';
        bgEl.classList.remove('rs-hero-bg-img--visible');
      }
    }

    /* Mobile banner — fallback to desktop if no mobile image */
    if (bgElMobile) {
      var mSrc = bgImgMobile || bgImg;
      if (mSrc) {
        bgElMobile.src = mSrc;
        bgElMobile.classList.add('rs-hero-bg-img--visible');
      } else {
        bgElMobile.src = '';
        bgElMobile.classList.remove('rs-hero-bg-img--visible');
      }
    }
  }

  /* ══════════════════════════════════════════════════════════
     BUILD PRODUCT CARD — used in Panel A (product_row sliders)
     Includes Add-to-Cart and wishlist functionality
  ══════════════════════════════════════════════════════════ */
  function buildProductCard(p, idx) {
    var bg = d.cardColors[idx % 3];
    var rawSrc = null;
    if (p.featured_image) {
      rawSrc = (typeof p.featured_image === 'object') ? p.featured_image.src : p.featured_image;
    } else if (p.images && p.images[0]) {
      rawSrc = p.images[0].src;
    }
    var imgSrc = fixImg(rawSrc);
    var price  = fmtPrice(p.price);
    var cpHtml = '';
    if (p.compare_at_price && parseInt(p.compare_at_price) > parseInt(p.price)) {
      cpHtml = '<span class="rs-card-compare">' + fmtPrice(p.compare_at_price) + '</span>';
    }
    var vid  = (p.variants && p.variants[0]) ? p.variants[0].id : '';
    var url  = '/products/' + p.handle;
    var alt  = (p.title || '').replace(/"/g, '&quot;');
    var desc = (p.body_html || '').replace(/<[^>]*>/g, '').substring(0, 80);
    var imgHtml = imgSrc
      ? '<img src="' + imgSrc + '" alt="' + alt + '" loading="lazy" class="rs-cimg">'
      : '<div class="rs-card-no-img">No Image</div>';

    var wl   = JSON.parse(localStorage.getItem('rs_wishlist') || '[]');
    var isWL = wl.indexOf(p.handle) !== -1;

    return [
      '<div class="rs-card" style="--rs-card-cbg:' + bg + '">',
        '<div class="rs-card-inner">',
          '<a href="' + url + '" class="rs-card-img-link">' + imgHtml + '</a>',
          '<button class="rs-wishlist-toggle' + (isWL ? ' rs-wishlisted' : '') + '" data-handle="' + p.handle + '" aria-label="Add to Wishlist">',
            '<svg viewBox="0 0 24 24" fill="' + (isWL ? 'currentColor' : 'none') + '" stroke="currentColor" stroke-width="2" width="20" height="20">',
              '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
            '</svg>',
          '</button>',
          '<div class="rs-card-btns">',
            '<button onclick="rsATC(\'' + vid + '\',this)" class="rs-btn-atc">Add to cart</button>',
            '<a href="' + url + '?buy=true" class="rs-btn-buy">Buy now</a>',
          '</div>',
        '</div>',
        '<div class="rs-card-body">',
          '<p class="rs-card-title"><a href="' + url + '" class="rs-card-title-link">' + (p.title || '') + '</a></p>',
          desc ? '<p class="rs-card-desc">' + desc + '</p>' : '',
          '<div class="rs-card-price">' + price + cpHtml + '</div>',
        '</div>',
      '</div>'
    ].join('');
  }

  /* ══════════════════════════════════════════════════════════
     BUILD COLLECTION CARD — used in Panel B (sub-collection grid)
     No ATC / wishlist — clicking navigates to the collection page
  ══════════════════════════════════════════════════════════ */
  function buildCollectionCard(sub, idx) {
    var bg  = d.cardColors[idx % 3];
    var alt = (sub.title || '').replace(/"/g, '&quot;');
    var imgHtml = sub.img
      ? '<img src="' + sub.img + '" alt="' + alt + '" loading="lazy" class="rs-cimg">'
      : '<div class="rs-card-no-img">No Image</div>';

    return [
      '<div class="rs-card rs-col-card" style="--rs-card-cbg:' + bg + '">',
        '<div class="rs-card-inner">',
          '<a href="' + sub.url + '" class="rs-card-img-link">' + imgHtml + '</a>',
          /* Full-width "Shop Now →" button (no ATC, no wishlist for collection cards) */
          '<div class="rs-card-btns">',
            '<a href="' + sub.url + '" class="rs-btn-buy rs-col-explore">Shop Now →</a>',
          '</div>',
        '</div>',
        '<div class="rs-card-body">',
          '<p class="rs-card-title"><a href="' + sub.url + '" class="rs-card-title-link">' + (sub.title || '') + '</a></p>',
          sub.desc ? '<p class="rs-card-desc">' + sub.desc + '</p>' : '',
        '</div>',
      '</div>'
    ].join('');
  }

  /* ── Fetch products for a collection via AJAX (used by product sliders) ── */
  function fetchProducts(handle, cb) {
    if (productCache[handle]) { cb(productCache[handle]); return; }
    fetch('/collections/' + handle + '/products.json?limit=50')
      .then(function (r) { return r.json(); })
      .then(function (data) { productCache[handle] = data.products || []; cb(productCache[handle]); })
      .catch(function ()   { cb([]); });
  }

  /* ══════════════════════════════════════════════════════════════════
     SHOW SUB-COLLECTIONS (Panel B)
     Called when a nav icon is clicked.
     Reads pre-embedded data from window.rsShopData.subCollections —
     no fetch needed, renders instantly.
  ══════════════════════════════════════════════════════════════════ */
  function showSubCollections(handle, label) {
    var multi  = document.getElementById('rs-panel-multi');
    var single = document.getElementById('rs-panel-single');
    var grid   = document.getElementById('rs-single-grid');
    var vaWrap = document.getElementById('rs-single-viewall');
    var vaLink = document.getElementById('rs-single-viewall-link');
    var hEl    = document.getElementById('rs-single-heading');
    var subEl  = document.getElementById('rs-single-subheading');
    var crumb  = document.getElementById('rs-breadcrumb-col');
    var crumbN = document.getElementById('rs-breadcrumb-col-name');

    /* Update breadcrumb */
    if (crumb)  crumb.classList.remove('rs-hidden');
    if (crumbN) crumbN.textContent = label;

    /* Update panel heading */
    if (hEl)  hEl.textContent  = label;
    if (subEl) subEl.textContent = d.singleSubheading || '';

    /* Switch from Panel A to Panel B */
    multi.classList.add('rs-hidden');
    single.classList.remove('rs-hidden');

    /* Remove any leftover slider arrows from a previous view */
    var sWrap = grid.parentElement;
    sWrap.querySelectorAll('.rs-arr').forEach(function (a) { a.remove(); });
    sWrap.style.overflow = '';
    sWrap.style.position = '';

    /* Get sub-collection array for this category (pre-embedded, no fetch) */
    var subs = (d.subCollections && d.subCollections[handle]) || [];

    /* Reset grid to a static grid layout (not a slider) */
    grid.className    = 'rs-single-grid';
    grid.style.transform = '';
    grid.removeAttribute('data-page');
    grid.removeAttribute('data-ppr');

    if (!subs.length) {
      /* Show a helpful message in the Shopify editor if no sub-collections are set up */
      grid.innerHTML = [
        '<p style="color:#666;font-size:14px;padding:30px 0;grid-column:1/-1;text-align:center;">',
          'No sub-categories found for this section.<br>',
          'Add <strong>Sub-Collection Card</strong> blocks in the editor and set Parent Category Handle to <em>' + handle + '</em>',
        '</p>'
      ].join('');
      if (vaWrap) vaWrap.classList.add('rs-hidden');
    } else {
      /* Render collection cards */
      grid.innerHTML = subs.map(function (sub, i) { return buildCollectionCard(sub, i); }).join('');

      /* "View All" link → parent collection page so user can browse all products */
      if (vaWrap) vaWrap.classList.remove('rs-hidden');
      if (vaLink) {
        vaLink.href        = '/collections/' + handle;
        vaLink.textContent = 'View All ' + label + ' →';
      }
    }

    setHash(handle);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ── Push/replace URL hash (enables back button and sharable URLs) ── */
  function setHash(hash) {
    if (history.replaceState) {
      history.replaceState(null, '', hash ? '#' + hash : window.location.pathname + window.location.search);
    }
  }

  /* ══════════════════════════════════════════════════════════════════
     NAV ICON CLICK — update hero + show sub-collections for that category
  ══════════════════════════════════════════════════════════════════ */
  window.rsSelectCollection = function (btn) {
    var handle = btn.getAttribute('data-handle');
    var label  = btn.getAttribute('data-label');
    if (!handle) return;

    /* Mark active icon */
    document.querySelectorAll('.rs-nav-icon').forEach(function (b) { b.classList.remove('rs-nav-active'); });
    btn.classList.add('rs-nav-active');

    /* Update hero banner image */
    var col = d.collections[handle];
    if (col) {
      updateHero(col.title, col.description, col.bannerImg, col.productImg, col.bannerImgMobile);
    } else {
      updateHero(label, d.defaultDesc, d.defaultBgImg, d.defaultProductImg, d.defaultBgImgMobile);
    }

    /* Show sub-collection cards for this category */
    showSubCollections(handle, label);
  };

  /* ══════════════════════════════════════════════════════════════════
     "SHOP ALL" CLICK — restore default multi-row Panel A view
  ══════════════════════════════════════════════════════════════════ */
  window.rsShowDefault = function (btn) {
    document.querySelectorAll('.rs-nav-icon').forEach(function (b) { b.classList.remove('rs-nav-active'); });
    btn.classList.add('rs-nav-active');

    /* Restore default hero */
    updateHero(d.defaultTitle, d.defaultDesc, d.defaultBgImg, d.defaultProductImg, d.defaultBgImgMobile);

    /* Show Panel A, hide Panel B */
    document.getElementById('rs-panel-multi').classList.remove('rs-hidden');
    document.getElementById('rs-panel-single').classList.add('rs-hidden');

    /* Hide breadcrumb sub-item */
    var crumb = document.getElementById('rs-breadcrumb-col');
    if (crumb) crumb.classList.add('rs-hidden');

    setHash('');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  /* ══════════════════════════════════════════════════════════════════
     SLIDER — advance/retreat a product row by one page
     Used by the prev/next arrows in Panel A product rows
  ══════════════════════════════════════════════════════════════════ */
  window.rsSlider = function (id, dir) {
    var track = document.getElementById(id);
    if (!track) return;

    var cards = Array.from(track.querySelectorAll('.rs-card'));
    var ppr   = parseInt(track.dataset.ppr) || 3;
    var total = cards.length;
    if (total <= ppr) return;

    var cur  = parseInt(track.dataset.page || '0');
    var next = Math.max(0, Math.min(cur + dir, total - ppr));
    track.dataset.page = next;

    var gap       = parseInt(getComputedStyle(track).gap) || 18;
    var cardWidth = cards[0] ? cards[0].offsetWidth : 0;
    track.style.transform = 'translateX(-' + (next * (cardWidth + gap)) + 'px)';

    /* Toggle arrow disabled states */
    var wrap    = track.closest('.rs-slider-wrap') || track.parentElement;
    var prevBtn = wrap && wrap.querySelector('.rs-arr--prev');
    var nextBtn = wrap && wrap.querySelector('.rs-arr--next');
    if (prevBtn) prevBtn.classList.toggle('rs-arr--hidden', next === 0);
    if (nextBtn) nextBtn.classList.toggle('rs-arr--hidden', next >= total - ppr);
  };

  /* ══════════════════════════════════════════════════════════════════
     FAQ ACCORDION
  ══════════════════════════════════════════════════════════════════ */
  window.rsFaq = function (btn) {
    var answer = btn.parentElement.querySelector('.rs-faq-answer');
    var icon   = btn.querySelector('.rs-faq-icon');
    var isOpen = answer.classList.contains('rs-faq-answer--open');

    /* Close all first */
    document.querySelectorAll('.rs-faq-answer').forEach(function (a) { a.classList.remove('rs-faq-answer--open'); });
    document.querySelectorAll('.rs-faq-icon').forEach(function (i)   { i.classList.remove('rs-faq-icon--open'); });
    document.querySelectorAll('.rs-faq-btn').forEach(function (b)    { b.setAttribute('aria-expanded', 'false'); });

    /* Toggle clicked item */
    if (!isOpen) {
      answer.classList.add('rs-faq-answer--open');
      icon.classList.add('rs-faq-icon--open');
      btn.setAttribute('aria-expanded', 'true');
    }
  };

  /* ══════════════════════════════════════════════════════════════════
     ANIMATIONS
  ══════════════════════════════════════════════════════════════════ */

  /* Particle burst on ATC click */
  function burstParticles(fromBtn) {
    var rect   = fromBtn.getBoundingClientRect();
    var cx     = rect.left + rect.width  / 2;
    var cy     = rect.top  + rect.height / 2;
    var colors = ['#2e7d32', '#f9a825', '#c62828', '#0277bd', '#558b2f'];
    var count  = 10;

    for (var i = 0; i < count; i++) {
      (function (i) {
        var p     = document.createElement('div');
        p.className = 'rs-particle';
        var angle = (i / count) * 2 * Math.PI;
        var dist  = 50 + Math.random() * 40;

        p.style.left        = (cx - 4) + 'px';
        p.style.top         = (cy - 4) + 'px';
        p.style.background  = colors[i % colors.length];
        p.style.setProperty('--px', (Math.cos(angle) * dist) + 'px');
        p.style.setProperty('--py', (Math.sin(angle) * dist) + 'px');
        p.style.animationDelay = (Math.random() * 0.1) + 's';

        document.body.appendChild(p);
        p.addEventListener('animationend', function () { p.remove(); });
      })(i);
    }
  }

  /* Heart flies from wishlist button toward header wishlist icon */
  function flyHeartToWishlist(fromBtn) {
    var wishlistIcon =
      document.getElementById('rs-wishlist-count') ||
      document.querySelector('.rs-wishlist-btn') ||
      document.querySelector('[href="/pages/wishlist"]');
    if (!wishlistIcon) return;

    var fromRect = fromBtn.getBoundingClientRect();
    var toRect   = wishlistIcon.getBoundingClientRect();

    var heart = document.createElement('div');
    heart.className = 'rs-fly-heart';
    heart.innerHTML = '❤️';
    heart.style.left = (fromRect.left + fromRect.width  / 2 - 11) + 'px';
    heart.style.top  = (fromRect.top  + fromRect.height / 2 - 11) + 'px';

    var dx = toRect.left + toRect.width  / 2 - (fromRect.left + fromRect.width  / 2);
    var dy = toRect.top  + toRect.height / 2 - (fromRect.top  + fromRect.height / 2);
    heart.style.setProperty('--fly-x',  (dx * 0.5) + 'px');
    heart.style.setProperty('--fly-y',  (dy * 0.5) + 'px');
    heart.style.setProperty('--fly-x2', dx + 'px');
    heart.style.setProperty('--fly-y2', dy + 'px');

    document.body.appendChild(heart);
    heart.addEventListener('animationend', function () { heart.remove(); });
  }

  /* ══════════════════════════════════════════════════════════════════
     ADD TO CART — with particle + flash animation
  ══════════════════════════════════════════════════════════════════ */
  window.rsATC = function (variantId, btn) {
    if (btn.disabled) return;

    burstParticles(btn);
    btn.classList.remove('rs-atc-flash');
    void btn.offsetWidth; /* force reflow to restart animation */
    btn.classList.add('rs-atc-flash');
    btn.addEventListener('animationend', function () { btn.classList.remove('rs-atc-flash'); }, { once: true });

    var orig   = btn.textContent;
    btn.textContent = 'Adding...';
    btn.disabled    = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      btn.textContent = 'Added ✓';
      document.dispatchEvent(new CustomEvent('cart:updated'));
      setTimeout(function () { btn.textContent = orig; btn.disabled = false; }, 1600);
    })
    .catch(function () {
      btn.textContent = 'Error!';
      setTimeout(function () { btn.textContent = orig; btn.disabled = false; }, 1600);
    });
  };

  /* ══════════════════════════════════════════════════════════════════
     WISHLIST — localStorage-based, event delegation
  ══════════════════════════════════════════════════════════════════ */
  function getWL() { return JSON.parse(localStorage.getItem('rs_wishlist') || '[]'); }
  function setWL(wl) {
    localStorage.setItem('rs_wishlist', JSON.stringify(wl));
    window.dispatchEvent(new Event('wishlist:updated'));
  }

  /* Sync all visible wishlist buttons to current localStorage state */
  function updateAllWishlistBtns() {
    var wl = getWL();
    document.querySelectorAll('.rs-wishlist-toggle').forEach(function (btn) {
      var handle = btn.dataset.handle;
      if (!handle) return;
      var active = wl.indexOf(handle) !== -1;
      btn.classList.toggle('rs-wishlisted', active);
      var svg = btn.querySelector('svg');
      if (svg) svg.setAttribute('fill', active ? 'currentColor' : 'none');
    });
  }

  /* Single delegated listener on document for all wishlist buttons */
  document.addEventListener('click', function (e) {
    var wlBtn = e.target.closest('.rs-wishlist-toggle');
    if (!wlBtn) return;

    var handle = wlBtn.dataset.handle;
    if (!handle) return;

    var wl     = getWL();
    var idx    = wl.indexOf(handle);
    var adding = idx === -1;

    if (adding) { wl.push(handle); flyHeartToWishlist(wlBtn); }
    else        { wl.splice(idx, 1); }

    /* Pulse animation */
    wlBtn.classList.remove('rs-wl-pulse');
    void wlBtn.offsetWidth;
    wlBtn.classList.add('rs-wl-pulse');
    wlBtn.addEventListener('animationend', function () { wlBtn.classList.remove('rs-wl-pulse'); }, { once: true });

    setWL(wl);
    updateAllWishlistBtns();
  });

  updateAllWishlistBtns();
  window.addEventListener('wishlist:updated', updateAllWishlistBtns);

  /* ══════════════════════════════════════════════════════════════════
     INIT — set default hero on page load + handle URL hash routing
     e.g. /pages/agri-shop#seeds will auto-open the Seeds category
  ══════════════════════════════════════════════════════════════════ */
  (function init() {
    var hash = window.location.hash.replace('#', '');
    if (hash) {
      /* Hash present — find and click the matching nav icon */
      var btn = document.querySelector('.rs-nav-icon[data-handle="' + hash + '"]');
      if (btn) {
        setTimeout(function () { rsSelectCollection(btn); }, 100);
      } else {
        /* Hash exists but no matching nav button — still load default hero */
        updateHero(d.defaultTitle, d.defaultDesc, d.defaultBgImg, d.defaultProductImg, d.defaultBgImgMobile);
      }
    } else {
      /* No hash — show default hero and Panel A */
      updateHero(d.defaultTitle, d.defaultDesc, d.defaultBgImg, d.defaultProductImg, d.defaultBgImgMobile);
    }
  })();

})();
</script>


