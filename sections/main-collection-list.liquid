{%- comment -%} ══════════ ANIMATION CSS ══════════ {%- endcomment -%}
<style>

  /* ── Flying heart: animates from wishlist button to the wishlist icon in header ── */
  .rs-fly-heart {
    position: fixed;
    pointer-events: none;
    z-index: 99999;
    font-size: 22px;
    color: #e53e3e;
    animation: rsFlyToWishlist 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    will-change: transform, opacity;
  }
  @keyframes rsFlyToWishlist {
    0%   { transform: scale(1)   translate(0, 0);                             opacity: 1; }
    60%  { transform: scale(1.4) translate(var(--fly-x),  var(--fly-y));      opacity: 1; }
    100% { transform: scale(0.3) translate(var(--fly-x2), var(--fly-y2));     opacity: 0; }
  }

  /* ── Add-to-cart particle burst ── */
  .rs-particle {
    position: fixed;
    pointer-events: none;
    z-index: 99999;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: rsParticleBurst 0.7s ease-out forwards;
    will-change: transform, opacity;
  }
  @keyframes rsParticleBurst {
    0%   { transform: translate(0, 0) scale(1); opacity: 1; }
    100% { transform: translate(var(--px), var(--py)) scale(0); opacity: 0; }
  }

  /* ── ATC button flash on click ── */
  .rs-btn-atc.rs-atc-flash { animation: rsAtcFlash 0.4s ease; }
  @keyframes rsAtcFlash {
    0%   { transform: scale(1); }
    30%  { transform: scale(0.92); filter: brightness(1.3); }
    60%  { transform: scale(1.06); }
    100% { transform: scale(1); }
  }

  /* ── Wishlist button pulse on toggle ── */
  .rs-wishlist-toggle.rs-wl-pulse { animation: rsWlPulse 0.4s ease; }
  @keyframes rsWlPulse {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.5); }
    100% { transform: scale(1); }
  }

  /* ── Sub-collection card: gentle lift on hover ── */
  .rs-col-card { transition: transform 0.25s ease, box-shadow 0.25s ease; }
  .rs-col-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  }

</style>


{%- comment -%} ══════════ HTML STRUCTURE ══════════ {%- endcomment -%}
<div id="rs-section-{{ section.id }}" class="rs-section">

  {%- comment -%} ── Hero Banner (background image changes on category selection) ── {%- endcomment -%}
  <div id="rs-hero" class="rs-hero">
    <div id="rs-hero-bg" class="rs-hero-bg">
      <img id="rs-hero-bg-img"        src="" alt="" class="rs-hero-bg-img">
      <img id="rs-hero-bg-img-mobile" src="" alt="" class="rs-hero-bg-img rs-hero-bg-img--mobile">
    </div>
  </div>

  {%- comment -%} ── Navigation Icons Row (main agriculture categories) ── {%- endcomment -%}
  {% if section.settings.show_icons_row %}
  <div class="rs-icons-row">
    <div class="rs-icons-wrap">

      {%- comment -%} "Shop All" button — resets to default multi-row view {%- endcomment -%}
      <button class="rs-nav-icon rs-nav-active" onclick="rsShowDefault(this)" aria-label="All Products">
        <div class="rs-nav-circle rs-nav-circle--all">
          {% if section.settings.all_icon_image != blank %}
            <img src="{{ section.settings.all_icon_image | image_url: width: 160 }}" alt="All Products" class="rs-icon-img">
          {% else %}
            <span class="rs-icon-emoji">🌱</span>
          {% endif %}
        </div>
        <span class="rs-icon-label">{{ section.settings.all_icon_label | default: 'All Products' }}</span>
      </button>

      {%- comment -%} Dynamic category icons from nav_icon blocks {%- endcomment -%}
      {% for block in section.blocks %}
        {% if block.type == 'nav_icon' %}
          {%- assign col        = block.settings.nav_collection -%}
          {%- assign col_handle = col.handle | default: '' -%}
          <button class="rs-nav-icon"
            onclick="rsSelectCollection(this)"
            data-handle="{{ col_handle }}"
            data-label="{{ block.settings.icon_label | escape }}"
            aria-label="{{ block.settings.icon_label | escape }}"
            style="--rs-this-icon-bg: {{ block.settings.icon_bg }}; --rs-this-icon-bdr: {{ block.settings.icon_border_color }};"
            {{ block.shopify_attributes }}>
            <div class="rs-nav-circle rs-nav-circle--col">
              {% if block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | image_url: width: 160 }}" alt="{{ block.settings.icon_label }}" class="rs-icon-img">
              {% elsif col != blank and col.image != blank %}
                <img src="{{ col.image | image_url: width: 160 }}" alt="{{ block.settings.icon_label }}" class="rs-icon-img">
              {% endif %}
            </div>
            <span class="rs-icon-label">{{ block.settings.icon_label }}</span>
          </button>
        {% endif %}
      {% endfor %}

    </div>
  </div>
  {% endif %}

  <div class="rs-page-bg" {% if section.settings.page_bg != blank %}style="background-image: url('{{ section.settings.page_bg | image_url: width: 2000 }}'); background-size: cover;"{% endif %}>

    {%- comment -%} ── Breadcrumb Trail ── {%- endcomment -%}
    {% if section.settings.show_breadcrumb %}
    <div class="rs-breadcrumb-wrap">
      <a href="{{ routes.root_url }}" class="rs-breadcrumb-link">Home</a>
      <span class="rs-breadcrumb-sep">›</span>
      <a href="#" class="rs-breadcrumb-link">{{ section.settings.breadcrumb_shop_text | default: 'Agri Shop' }}</a>
      <span id="rs-breadcrumb-col" class="rs-hidden">
        <span class="rs-breadcrumb-sep">›</span>
        <span id="rs-breadcrumb-col-name"></span>
      </span>
    </div>
    {% endif %}

    {%- comment -%} ── Main Content Area ── {%- endcomment -%}
    <div class="rs-main-content">
      <div class="rs-container">

        {%- comment -%}
          ════════════════════════════════════════════
          PANEL A — Default "Shop All" view
          Shows product_row blocks as horizontal sliders
          Visible on page load; hidden when a nav icon is clicked
          ════════════════════════════════════════════
        {%- endcomment -%}
        <div id="rs-panel-multi">
          {% for block in section.blocks %}
            {% if block.type == 'product_row' %}
              {%- assign row_col   = block.settings.row_collection -%}
              {%- assign slider_id = 'rss-' | append: block.id -%}
              <div class="rs-row" {{ block.shopify_attributes }}>

                <div class="rs-row-header">
                  <div class="top_collection">
                    <h2 class="rs-row-heading">{{ block.settings.row_heading }}</h2>
                    {% if block.settings.row_subheading != blank %}
                      <div class="rs-row-sub">
                        <div>{{ block.settings.row_subheading }}</div>
                      </div>
                    {% endif %}
                  </div>

                  {%- comment -%} Quality badges — configurable per row {%- endcomment -%}
                  <div class="rs-badges">
                    <div class="rs_badge_inner">
                      {% if block.settings.badge_certified %}
                        <img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Added-Preservatives-1.webp?v=1773949015" alt="Certified">
                        <div>Certified Seeds</div>
                      {% endif %}
                    </div>
                    <div class="rs_badge_inner">
                      {% if block.settings.badge_organic %}
                        <img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Added-Colours-1.webp?v=1773949015" alt="Organic">
                        <div>Organic Options</div>
                      {% endif %}
                    </div>
                    <div class="rs_badge_inner">
                      {% if block.settings.badge_quality %}
                        <img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Trans-Fat-1_9e98ae0d-c063-4a02-b5dc-38ec9e42f827.webp?v=1773949013" alt="Quality Assured">
                        <div>Quality Assured</div>
                      {% endif %}
                    </div>
                  </div>
                </div>

                {%- comment -%} Slider with optional prev/next arrows {%- endcomment -%}
                <div class="rs-slider-wrap">
                  {% if section.settings.show_arrows %}
                    <button class="rs-arr rs-arr--prev" onclick="rsSlider('{{ slider_id }}',-1)" aria-label="Previous">{{ 'slick-arrow.svg' | inline_asset_content }}</button>
                    <button class="rs-arr rs-arr--next" onclick="rsSlider('{{ slider_id }}',1)"  aria-label="Next">{{ 'slick-arrow.svg' | inline_asset_content }}</button>
                  {% endif %}

                  <div class="rs-slider-viewport">
                    <div id="{{ slider_id }}" class="rs-slider-track" data-page="0" data-ppr="{{ ppr }}">
                      {%- assign pi = 0 -%}
                      {% if row_col != blank %}
                        {% for product in row_col.products limit: 50 %}
                          {%- assign ci = pi | modulo: 3 -%}
                          {%- assign pi = pi | plus: 1 -%}
                          {%- if ci == 0 -%}{%- assign cbg = c1 -%}{%- elsif ci == 1 -%}{%- assign cbg = c2 -%}{%- else -%}{%- assign cbg = c3 -%}{%- endif -%}
                          <div class="rs-card rs-card--c{{ ci | plus: 1 }}" style="--rs-card-cbg: {{ cbg }};">
                            <div class="rs-card-inner">
                              <a href="{{ product.url }}" class="rs-card-img-link">
                                {% if product.featured_image != blank %}
                                  <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="lazy" class="rs-cimg">
                                {% else %}
                                  <div class="rs-card-no-img">No Image</div>
                                {% endif %}
                              </a>
                              <button class="rs-wishlist-toggle" data-handle="{{ product.handle }}" aria-label="Add to Wishlist">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                </svg>
                              </button>
                              <div class="rs-card-btns">
                                <button onclick="rsATC('{{ product.variants.first.id }}',this)" class="rs-btn-atc">Add to cart</button>
                                <a href="{{ product.url }}?buy=true" class="rs-btn-buy">Buy now</a>
                              </div>
                            </div>
                            <div class="rs-card-body">
                              <p class="rs-card-title"><a href="{{ product.url }}" class="rs-card-title-link">{{ product.title }}</a></p>
                              {% if product.description != blank %}<p class="rs-card-desc">{{ product.description | strip_html | truncate: 80 }}</p>{% endif %}
                              <div class="rs-card-price">
                                {{ product.price | money }}
                                {% if product.compare_at_price > product.price %}<span class="rs-card-compare">{{ product.compare_at_price | money }}</span>{% endif %}
                              </div>
                            </div>
                          </div>
                        {% endfor %}
                      {% else %}
                        {%- comment -%} Placeholder cards when no collection is assigned in editor {%- endcomment -%}
                        {% for i in (1..ppr) %}
                          {%- assign ci = forloop.index0 | modulo: 3 -%}
                          {%- if ci == 0 -%}{%- assign cbg = c1 -%}{%- elsif ci == 1 -%}{%- assign cbg = c2 -%}{%- else -%}{%- assign cbg = c3 -%}{%- endif -%}
                          <div class="rs-card rs-card-placeholder rs-card--c{{ ci | plus: 1 }}" style="--rs-card-cbg: {{ cbg }};">
                            <div class="rs-card-inner">
                              <div class="rs-card-no-img">Assign a collection in the editor</div>
                              <div class="rs-card-btns">
                                <div class="rs-btn-atc">Add to cart</div>
                                <div class="rs-btn-buy">Buy now</div>
                              </div>
                            </div>
                            <div class="rs-card-body">
                              <div class="rs-skel-line rs-skel-line--lg"></div>
                              <div class="rs-skel-line rs-skel-line--sm"></div>
                            </div>
                          </div>
                        {% endfor %}
                      {% endif %}
                    </div>
                  </div>
                </div>

              </div>
            {% endif %}
          {% endfor %}
        </div>
        {%- comment -%} /Panel A {%- endcomment -%}

        {%- comment -%}
          ════════════════════════════════════════════
          PANEL B — Category sub-collections view
          Hidden by default; shown when a nav icon is clicked.
          Displays a grid of sub-collection cards (no products, no ATC).
          Each card links directly to /collections/{handle}
          ════════════════════════════════════════════
        {%- endcomment -%}
        <div id="rs-panel-single" class="rs-hidden">

          <div class="rs-row-header">
            <div class="top_collection">
              <h2 id="rs-single-heading" class="rs-row-heading">{{ section.settings.single_col_heading | default: 'Select a Category' }}</h2>
              <p id="rs-single-subheading" class="rs-row-sub">{{ section.settings.single_col_subheading }}</p>
            </div>
            {%- comment -%} Quality badges for category view {%- endcomment -%}
            <div class="rs-badges">
              <div>
                {% if section.settings.single_badge_certified %}<img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Trans-Fat-1_9e98ae0d-c063-4a02-b5dc-38ec9e42f827.webp?v=1773949013" alt="Certified"><span>Certified Seeds</span>{% endif %}
              </div>
              <div>
                {% if section.settings.single_badge_organic %}<img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Added-Colours-1.webp?v=1773949015" alt="Organic"><span>Organic Options</span>{% endif %}
              </div>
              <div>
                {% if section.settings.single_badge_quality %}<img src="https://cdn.shopify.com/s/files/1/0817/1264/4332/files/No-Trans-Fat-1_9e98ae0d-c063-4a02-b5dc-38ec9e42f827.webp?v=1773949013" alt="Quality Assured"><span>Quality Assured</span>{% endif %}
              </div>
            </div>
          </div>

          {%- comment -%}
            Sub-collection cards grid — populated instantly by JS
            No async fetch; all data is pre-embedded in window.rsShopData.subCollections
          {%- endcomment -%}
          <div id="rs-single-grid" class="rs-single-grid"></div>

          {%- comment -%}
            "View All" link at bottom — JS rewrites href to /collections/{parent-handle}
            and updates the text to "View All {Category Name} →"
          {%- endcomment -%}
          <div id="rs-single-viewall" class="rs-viewall rs-hidden">
            <a id="rs-single-viewall-link" href="#" class="rs-btn-viewall">View All Products →</a>
          </div>

        </div>
        {%- comment -%} /Panel B {%- endcomment -%}

      </div>
    </div>

  </div>
  {%- comment -%} /rs-page-bg {%- endcomment -%}

  {%- comment -%} ══════════ FAQ ACCORDION ══════════ {%- endcomment -%}
  {%- assign faq_blocks = section.blocks | where: 'type', 'faq_item' -%}
  {% if faq_blocks.size > 0 %}
  <div class="rs-faq-section">
    <div class="rs-faq-inner">
      <div class="rs-faq-content">
        {% if section.settings.faq_heading != blank %}<h2 class="rs-faq-heading">{{ section.settings.faq_heading }}</h2>{% endif %}
        {%- assign fi = 0 -%}
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            {%- assign fi = fi | plus: 1 -%}
            <div class="rs-faq-item{% if fi == 1 %} rs-faq-item--first{% endif %}" {{ block.shopify_attributes }}>
              <button onclick="rsFaq(this)" class="rs-faq-btn" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
                <span class="rs-faq-q">{{ block.settings.question }}</span>
                <span class="rs-faq-icon{% if forloop.first %} rs-faq-icon--open{% endif %}">{{ section.settings.faq_icon }}</span>
              </button>
              <div class="rs-faq-answer{% if forloop.first %} rs-faq-answer--open{% endif %}">
                <div class="rs-faq-answer-inner">{{ block.settings.answer }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      {% if section.settings.faq_side_image != blank %}
        <div class="rs-faq-img-wrap">
          <img src="{{ section.settings.faq_side_image | image_url: width: 600 }}" alt="FAQ" class="rs-faq-img">
        </div>
      {% endif %}
    </div>
  </div>
  {% endif %}

</div>
