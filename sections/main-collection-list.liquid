{%- assign faq_blocks = section.blocks | where: 'type', 'faq_item' -%}
{% if faq_blocks.size > 0 %}
<div class="rs-faq-section">
  <div class="rs-faq-inner">
    <div class="rs-faq-content">
      {% if section.settings.faq_heading != blank %}<h2 class="rs-faq-heading">{{ section.settings.faq_heading }}</h2>{% endif %}
      {%- assign fi = 0 -%}
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          {%- assign fi = fi | plus: 1 -%}
          <div class="rs-faq-item{% if fi == 1 %} rs-faq-item--first{% endif %}" {{ block.shopify_attributes }}>
            <button onclick="rsFaq(this)" class="rs-faq-btn" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
              <span class="rs-faq-q">{{ block.settings.question }}</span>
              <span class="rs-faq-icon{% if forloop.first %} rs-faq-icon--open{% endif %}">{{ section.settings.faq_icon }}</span>
            </button>
            <div class="rs-faq-answer{% if forloop.first %} rs-faq-answer--open{% endif %}">
              <div class="rs-faq-answer-inner">{{ block.settings.answer }}</div>
            </div>
          </div>
        {% endif %}
