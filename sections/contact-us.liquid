
<style>
.contact-wrapper {
  display: flex;
  flex-wrap: wrap;
  background: linear-gradient(135deg, #5fa8d3, #4a90c2);
  padding: 50px;
  border-radius: 12px;
  color: #fff;
}

.contact-left {
  flex: 1;
  background: #1f4e79;
  padding: 30px;
  border-radius: 10px;
}

.contact-left h3 {
  margin-bottom: 20px;
}

.contact-left a {
  color: #fff;
  text-decoration: none;
  display: block;
  margin-bottom: 10px;
}

.contact-right {
  flex: 1;
  background: #fff;
  color: #333;
  padding: 30px;
  border-radius: 10px;
  margin-left: 20px;
}

.contact-right input,
.contact-right textarea {
  width: 100%;
  padding: 12px;
  margin-bottom: 15px;
  border: none;
  border-radius: 6px;
  background: #f2f2f2;
}

.contact-right button {
  background: #5fa8d3;
  color: #fff;
  padding: 12px 30px;
  border: none;
  border-radius: 25px;
  cursor: pointer;
}

.contact-right button:hover {
  background: #4a90c2;
}
</style>

<div class="contact-wrapper">

  <!-- LEFT SIDE -->
  <div class="contact-left">
    <h3>Contact Us</h3>

    <p>{{ section.settings.address }}</p>

    <a href="mailto:{{ section.settings.email }}">
      📧 {{ section.settings.email }}
    </a>

    <a href="tel:{{ section.settings.phone }}">
      📞 {{ section.settings.phone }}
    </a>

  </div>

  <!-- RIGHT SIDE -->
  <div class="contact-right">
    <h2>{{ section.settings.heading }}</h2>

    <form method="post" action="/contact#contact_form" id="contact_form">
      
      <input type="text" name="contact[name]" placeholder="Your Name" required>

      <input type="email" name="contact[email]" placeholder="Your Email" required>

      <textarea name="contact[body]" placeholder="Your Message" rows="5" required></textarea>

      <button type="submit">SEND</button>

    </form>
  </div>

</div>

{% schema %}
{
  "name": "Bhumi Agro Contact",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "Bhumi Agro, India"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "info@bhumiagro.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+91 9876543210"
    }
  ],
  "presets": [
    {
      "name": "Bhumi Agro Contact"
    }
  ]
}
{% endschema %}
