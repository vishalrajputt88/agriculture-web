{% style %}
.contact-section {
  max-width: 1100px;
  margin: auto;
  padding: 50px 20px;
  font-family: Arial, sans-serif;
}

.contact-heading {
  text-align: center;
  font-size: {{ section.settings.heading_size }}px;
  font-weight: 700;
  margin-bottom: 40px;
}

.contact-wrapper {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
}

.contact-card {
  background: #f9f9f9;
  padding: 25px;
  border-radius: 12px;
}

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 20px;
}

.contact-icon {
  font-size: 20px;
}

.contact-title {
  font-weight: 600;
}

.contact-form {
  background: #ffffff;
  padding: 25px;
  border-radius: 12px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}

.contact-form input,
.contact-form textarea {
  width: 100%;
  padding: 12px;
  margin-bottom: 12px;
  border-radius: 8px;
  border: 1px solid #ddd;
  font-size: 14px;
}

.contact-form textarea {
  min-height: 120px;
}

.contact-form button {
  width: 100%;
  padding: 12px;
  background: {{ section.settings.button_color }};
  color: #fff;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
}

@media(max-width: 768px){
  .contact-wrapper {
    grid-template-columns: 1fr;
  }
}
{% endstyle %}

<div class="contact-section">

  <h2 class="contact-heading">
    {{ section.settings.heading }}
  </h2>

  <div class="contact-wrapper">

    <!-- Left Info -->
    <div class="contact-card">

      <div class="contact-item">
        <div class="contact-icon">📍</div>
        <div>
          <div class="contact-title">Address</div>
          <div>{{ section.settings.address }}</div>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">📞</div>
        <div>
          <div class="contact-title">Phone</div>
          <div>{{ section.settings.phone }}</div>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">✉️</div>
        <div>
          <div class="contact-title">Email</div>
          <div>{{ section.settings.email }}</div>
        </div>
      </div>

    </div>

    <!-- Right Form -->
    <div class="contact-form">
      {% form 'contact' %}
        <input type="text" name="contact[name]" placeholder="Your Name" required>
        <input type="email" name="contact[email]" placeholder="Your Email" required>
        <textarea name="contact[body]" placeholder="Your Message"></textarea>
        <button type="submit">Send Message</button>
      {% endform %}
    </div>

  </div>

</div>

{% schema %}
{
  "name": "Contact Bhumi",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 20,
      "max": 60,
      "step": 1,
      "default": 36
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "Bhumi Agro, Madhya Pradesh, India"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+91 9876543210"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "support@bhumiagro.com"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#2e7d32"
    }
  ],
  "presets": [
    {
      "name": "Contact Bhumi"
    }
  ]
}
{% endschema %}