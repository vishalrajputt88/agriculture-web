{% style %}
.contact-section {
  max-width: 1000px;
  margin: auto;
  padding: 40px 20px;
  font-family: Arial, sans-serif;
}

.contact-heading {
  text-align: center;
  font-size: {{ section.settings.heading_size }}px;
  margin-bottom: 20px;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
}

.contact-info {
  font-size: 16px;
}

.contact-box {
  margin-bottom: 15px;
}

.contact-form input,
.contact-form textarea {
  width: 100%;
  padding: 10px;
  margin-bottom: 10px;
  border: 1px solid #ccc;
}

.contact-form button {
  background: #2e7d32;
  color: #fff;
  padding: 10px 20px;
  border: none;
  cursor: pointer;
}
{% endstyle %}

<div class="contact-section">

  <h2 class="contact-heading">
    {{ section.settings.heading }}
  </h2>

  <div class="contact-grid">

    <!-- Left Side Info -->
    <div class="contact-info">

      <div class="contact-box">
        <strong>Address:</strong><br>
        {{ section.settings.address }}
      </div>

      <div class="contact-box">
        <strong>Phone:</strong><br>
        {{ section.settings.phone }}
      </div>

      <div class="contact-box">
        <strong>Email:</strong><br>
        {{ section.settings.email }}
      </div>

    </div>

    <!-- Right Side Form -->
    <div class="contact-form">
      {% form 'contact' %}
        <input type="text" name="contact[name]" placeholder="Your Name" required>
        <input type="email" name="contact[email]" placeholder="Your Email" required>
        <textarea name="contact[body]" placeholder="Your Message"></textarea>
        <button type="submit">Send Message</button>
      {% endform %}
    </div>

  </div>

</div>

{% schema %}
{
  "name": "Contact Bhumi Agro",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 20,
      "max": 50,
      "step": 1,
      "default": 32
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "Your company address here"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+91 9876543210"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "support@bhumiagro.com"
    }
  ],

  "presets": [
    {
      "name": "Contact Bhumi Agro"
    }
  ]
}
{% endschema %}