{% schema %}
{
  "name": "Bhumi Agro Contact Pro",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "Bhumi Agro, India"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "info@bhumiagro.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+91 9876543210"
    }
  ],
  "presets": [
    {
      "name": "Bhumi Agro Contact Pro"
    }
  ]
}
{% endschema %}

<style>
/* OUTER SECTION */
.bhumi-contact-section {
  padding: 80px 20px;
  {% comment %} background: linear-gradient(135deg, #6fb1d6, #4a90c2); {% endcomment %}
   background: #16a30a;
}

/* CENTER CONTAINER */
.bhumi-container {
  max-width: 1200px;
  margin: auto;
}

/* MAIN BOX */
.bhumi-contact-wrapper {
  display: flex;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 20px 50px rgba(0,0,0,0.15);
}

/* LEFT PANEL */
.bhumi-left {
  width: 40%;
  background: #254e73;
  color: #fff;
  padding: 50px;
}

.bhumi-left h3 {
  font-size: 32px;
  margin-bottom: 25px;
}

.bhumi-left p {
  margin-bottom: 15px;
  opacity: 0.9;
}

.bhumi-left a {
  display: block;
  color: #fff;
  text-decoration: none;
  margin-bottom: 12px;
  font-size: 16px;
  transition: 0.3s;
}

.bhumi-left a:hover {
  opacity: 0.8;
}

/* RIGHT PANEL */
.bhumi-right {
  width: 60%;
  background: #f4f4f4;
  padding: 50px;
}

.bhumi-right h2 {
  font-size: 40px;
  margin-bottom: 25px;
  color: #333;
}

/* INPUTS */
.bhumi-right input,
.bhumi-right textarea {
  width: 100%;
  padding: 16px;
  margin-bottom: 18px;
  border: none;
  border-radius: 8px;
  background: #eaeaea;
  font-size: 15px;
}

.bhumi-right textarea {
  min-height: 140px;
}

/* BUTTON */
.bhumi-btn {
  background: linear-gradient(135deg, #6fb1d6, #4a90c2);
  color: #fff;
  border: none;
  padding: 14px 40px;
  border-radius: 30px;
  font-size: 14px;
  cursor: pointer;
  transition: 0.3s;
}

.bhumi-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 20px rgba(0,0,0,0.15);
}

/* RESPONSIVE */
@media(max-width: 768px){
  .bhumi-contact-wrapper {
    flex-direction: column;
  }

  .bhumi-left,
  .bhumi-right {
    width: 100%;
  }

  .bhumi-right h2 {
    font-size: 28px;
  }
}
</style>

<section class="bhumi-contact-section">
  <div class="bhumi-container">

    <div class="bhumi-contact-wrapper">

      <!-- LEFT -->
      <div class="bhumi-left">
        <h3>Contact Us</h3>

        <p>{{ section.settings.address }}</p>

        <a href="mailto:{{ section.settings.email }}">
          📧 {{ section.settings.email }}
        </a>

        <a href="tel:{{ section.settings.phone }}">
          📞 {{ section.settings.phone }}
        </a>
      </div>

      <!-- RIGHT -->
      <div class="bhumi-right">
        <h2>{{ section.settings.heading }}</h2>

        {% form 'contact' %}

          <input type="text" name="contact[name]" placeholder="Your Name" required>

          <input type="email" name="contact[email]" placeholder="Your Email" required>

          <input type="tel" name="contact[phone]" placeholder="Your Phone Number">

          <textarea name="contact[body]" placeholder="Your Message" required></textarea>

          <button type="submit" class="bhumi-btn">SEND</button>

        {% endform %}
      </div>

    </div>

  </div>
</section>