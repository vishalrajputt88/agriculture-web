{% style %}
.faq-section {
  max-width: 900px;
  margin: auto;
  padding: 40px 20px;
}

.faq-item {
  border-bottom: 1px solid #ddd;
  padding: 15px 0;
}

.faq-question {
  cursor: pointer;
  font-weight: bold;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.faq-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.faq-icon img {
  width: 20px;
  height: 20px;
}

.faq-count {
  font-weight: bold;
}

.faq-answer {
  display: none;
  margin-top: 10px;
}

.faq-item.active .faq-answer {
  display: block;
}
{% endstyle %}

<div class="faq-section">

  <h2>{{ section.settings.heading }}</h2>

  {% for block in section.blocks %}
    <div class="faq-item">
      
      <div class="faq-question">
        
        <div class="faq-left">

          {% if section.settings.show_count %}
            <span class="faq-count">{{ forloop.index }}.</span>
          {% endif %}

          {% if block.settings.icon_image != blank %}
            <span class="faq-icon">
              <img src="{{ block.settings.icon_image | image_url }}" alt="icon">
            </span>
          {% elsif block.settings.icon_text != blank %}
            <span class="faq-icon">
              {{ block.settings.icon_text }}
            </span>
          {% endif %}

          <span>{{ block.settings.question }}</span>

        </div>

        <span>+</span>

      </div>

      <div class="faq-answer">
        {{ block.settings.answer }}
      </div>

    </div>
  {% endfor %}

</div>

<script>
document.querySelectorAll('.faq-question').forEach((item) => {
  item.addEventListener('click', () => {
    const parent = item.parentElement;
    parent.classList.toggle('active');
  });
});
</script>

{% schema %}
{
  "name": "FAQ Bhumi Agro",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show Auto Numbering",
      "default": true
    }
  ],

  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Upload Icon Image"
        },
        {
          "type": "text",
          "id": "icon_text",
          "label": "Or Use Emoji/Icon Text",
          "default": "🌱"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Enter your question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Enter your answer"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "FAQ Bhumi Agro"
    }
  ]
}
{% endschema %}